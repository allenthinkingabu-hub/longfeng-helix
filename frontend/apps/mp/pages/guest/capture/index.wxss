/* P-GUEST-CAPTURE · MP guest capture · trace mockup 15_guest_capture.html
 * 暗色相机背景 + ConsentBar + 74rpx 主 Shutter
 */
.gc-root {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background: #0B0D12;
  color: #F2F4F8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  overflow: hidden;
  padding-bottom: 40rpx;
}

/* Anonymous Shell · top nav (logo + brand + 登录 CTA) */
.gc-anon-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 36rpx;
  background: rgba(0, 0, 0, 0.45);
  backdrop-filter: blur(12rpx);
}
.gc-anon-nav-brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}
.gc-anon-nav-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFD166;
  box-shadow: 0 0 12rpx #FFD166;
}
.gc-anon-nav-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}
.gc-anon-nav-signin {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* Quota banner · 黄色加粗 */
.gc-quota {
  margin: 24rpx 36rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 180, 84, 0.18), rgba(255, 90, 79, 0.14));
  border: 1rpx solid rgba(255, 209, 102, 0.35);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.gc-quota-ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: rgba(255, 209, 102, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.gc-quota-text {
  flex: 1;
  min-width: 0;
}
.gc-quota-title {
  font-size: 25rpx;
  font-weight: 800;
  color: #FFD166;
}
.gc-quota-desc {
  font-size: 21rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 2rpx;
}

/* Camera viewfinder (CAMERA_ACTIVE) */
.gc-camera {
  width: 100%;
  height: 50vh;
  background: #000;
  position: relative;
}
.gc-camera-frame {
  position: absolute;
  inset: 60rpx;
  border: 4rpx solid #FFD166;
  border-radius: 16rpx;
  pointer-events: none;
}

/* Subject chips (single-select horizontal) */
.gc-subjects {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 36rpx;
  overflow-x: auto;
  white-space: nowrap;
}
.gc-subject {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
  font-weight: 700;
}
.gc-subject-active {
  background: #fff;
  color: #0B0D12;
  border-color: #fff;
}

/* Consent card */
.gc-consent {
  margin: 24rpx 36rpx;
  padding: 28rpx;
  background: rgba(18, 21, 28, 0.85);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}
.gc-consent-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.gc-consent-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 26rpx;
  flex: none;
}
.gc-consent-check-unchecked {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}
.gc-consent-tx {
  font-size: 23rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.82);
  flex: 1;
}
.gc-badge-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}
.gc-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
}
.gc-badge-green {
  background: rgba(60, 212, 123, 0.12);
  color: #3CD47B;
  border: 1rpx solid rgba(60, 212, 123, 0.25);
}
.gc-badge-blue {
  background: rgba(76, 155, 255, 0.12);
  color: #4C9BFF;
  border: 1rpx solid rgba(76, 155, 255, 0.25);
}
.gc-badge-orange {
  background: rgba(255, 180, 84, 0.12);
  color: #FFB454;
  border: 1rpx solid rgba(255, 180, 84, 0.25);
}

/* Shutter row · 74rpx button + side buttons */
.gc-controls {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
  gap: 24rpx;
}
.gc-shutter-row {
  display: flex;
  align-items: center;
  gap: 60rpx;
}
.gc-shutter {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #fff;
  border: 8rpx solid rgba(255, 255, 255, 0.35);
  box-shadow: 0 0 0 12rpx rgba(255, 255, 255, 0.08);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0B0D12;
  font-size: 22rpx;
  font-weight: 800;
}
.gc-shutter-disabled {
  background: rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.5);
}
.gc-shutter-rec {
  position: absolute;
  top: -28rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

/* UPLOADING / ANALYZING phase indicator */
.gc-phase-indicator {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #FFD166;
}
.gc-phase-progress {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
}

/* READY 4 cards */
.gc-result {
  margin: 24rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.gc-result-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #3CD47B;
  margin-bottom: 16rpx;
  text-align: center;
}
.gc-result-card {
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.gc-result-key {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}
.gc-result-val {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
}
.gc-cta-save {
  margin: 32rpx 36rpx 24rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 24rpx;
  text-align: center;
  border: none;
}

/* QUOTA_EXHAUSTED 整页挡板 */
.gc-quota-blocker {
  position: fixed;
  inset: 0;
  background: #0B0D12;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  z-index: 100;
}
.gc-quota-blocker-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.gc-quota-blocker-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #FF5A4F;
  margin-bottom: 16rpx;
  text-align: center;
}
.gc-quota-blocker-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  margin-bottom: 32rpx;
}
.gc-quota-blocker-countdown {
  font-size: 22rpx;
  color: #FFD166;
  margin-bottom: 32rpx;
}
.gc-quota-blocker-cta {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 999rpx;
  border: none;
}

/* ERROR 顶部红条 */
.gc-error-banner {
  margin: 24rpx 36rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 90, 79, 0.18);
  border: 1rpx solid rgba(255, 90, 79, 0.4);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.gc-error-text {
  font-size: 24rpx;
  color: #FF5A4F;
  flex: 1;
}
.gc-error-retry {
  padding: 12rpx 24rpx;
  background: #FF5A4F;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  border-radius: 999rpx;
  border: none;
}
