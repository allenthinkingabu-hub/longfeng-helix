/* P-GUEST-CAPTURE · 严格按 mockup 15_guest_capture.html 重写 (2026-05-18)
   暗色取景器底 + 玻璃态浮层 UI · rpx scale 2x (mockup 393px → 750rpx) */

page {
  background: #0B0D12;
}

.gc-root {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background: #0B0D12;
  color: #F2F4F8;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  overflow: hidden;
}

/* ── Viewport · 暗色相机取景器底 (mockup line 25-30) ──────────────────── */
.gc-viewport {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(80% 60% at 50% 45%, #1b2239 0%, #0B0D12 75%),
    #000;
  overflow: hidden;
  z-index: 5;
}

.gc-viewport-scanline {
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    transparent 0,
    transparent 4rpx,
    rgba(255, 255, 255, 0.015) 4rpx,
    rgba(255, 255, 255, 0.015) 6rpx
  );
  opacity: 0.6;
  pointer-events: none;
}

/* ── Paper card · 模拟纸张 (mockup line 33-41) ─────────────────────────── */
.gc-paper {
  position: absolute;
  top: 300rpx;
  left: 50%;
  transform: translateX(-50%) rotate(-1.5deg);
  width: 560rpx;
  height: 760rpx;
  background: linear-gradient(180deg, #F7EFD7 0%, #EEE2C2 100%);
  border-radius: 12rpx;
  box-shadow: 0 36rpx 88rpx rgba(0, 0, 0, 0.55);
  padding: 44rpx 36rpx;
  color: #1C1C1E;
  overflow: hidden;
  z-index: 6;
}

.gc-paper::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 12rpx;
  background: repeating-linear-gradient(
    90deg,
    rgba(0, 0, 0, 0.12) 0,
    rgba(0, 0, 0, 0.12) 20rpx,
    transparent 20rpx,
    transparent 40rpx
  );
}

.gc-paper-qnum {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  color: #FF3B30;
  margin-bottom: 12rpx;
}

.gc-paper-title {
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  letter-spacing: 0.4rpx;
}

.gc-paper-q {
  font-size: 26rpx;
  line-height: 1.6;
  letter-spacing: 0.2rpx;
  font-family: "Times New Roman", Georgia, serif;
  margin-bottom: 12rpx;
}

.gc-paper-eq {
  margin: 20rpx 0;
  font-size: 30rpx;
  text-align: center;
  font-weight: 600;
  font-family: "Times New Roman", Georgia, serif;
}

.gc-paper-ans {
  margin-top: 28rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.12);
  font-size: 24rpx;
  color: #4B0082;
  line-height: 1.6;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.gc-paper-wrong {
  color: #FF3B30;
  text-decoration: line-through;
}

.gc-paper-redmark {
  position: absolute;
  top: 136rpx;
  right: 44rpx;
  font-family: "Brush Script MT", cursive;
  color: #FF3B30;
  font-size: 56rpx;
  transform: rotate(12deg);
  font-weight: 700;
}

/* ── Real camera (CAMERA_ACTIVE) ───────────────────────────────────────── */
.gc-camera {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 6;
}

/* ── Edge ROI corners · yellow brackets (mockup line 44-49)
   去掉框 border · 只保留 4 个 corner L · 更接近 mockup viewfinder 视觉
   corner 加大到 56rpx + 8rpx border · 鲜明 */
.gc-edges {
  position: absolute;
  top: 280rpx;
  left: 64rpx;
  right: 64rpx;
  height: 800rpx;
  border: 3rpx solid rgba(255, 209, 102, 0.5);
  border-radius: 16rpx;
  z-index: 11;
  pointer-events: none;
}

.gc-edge {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border: 8rpx solid #FFD166;
}

.gc-edge-tl { top: 0; left: 0; border-right: none; border-bottom: none; border-top-left-radius: 12rpx; }
.gc-edge-tr { top: 0; right: 0; border-left: none; border-bottom: none; border-top-right-radius: 12rpx; }
.gc-edge-bl { bottom: 0; left: 0; border-right: none; border-top: none; border-bottom-left-radius: 12rpx; }
.gc-edge-br { bottom: 0; right: 0; border-left: none; border-top: none; border-bottom-right-radius: 12rpx; }

/* ── AnonShell nav · glass back + brand chip + signin (mockup line 52-57) ── */
.gc-anon-nav {
  position: absolute;
  top: 24rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* WeChat capsule 让位 */
  padding-right: 200rpx;
}

.gc-anon-back {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.45);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gc-anon-back-icon {
  width: 32rpx;
  height: 32rpx;
}

.gc-anon-brand {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.35);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
}

.gc-anon-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFD166;
  box-shadow: 0 0 12rpx #FFD166;
}

.gc-anon-name {
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.gc-anon-signin {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  box-shadow: 0 12rpx 32rpx -8rpx rgba(76, 155, 255, 0.5);
}

/* ── Quota banner · 橙黄玻璃 (mockup line 60-64) ───────────────────────── */
.gc-quota {
  position: absolute;
  top: 120rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 25;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(255, 180, 84, 0.18), rgba(255, 90, 79, 0.14));
  border: 2rpx solid rgba(255, 209, 102, 0.35);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.gc-quota-ico {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: rgba(255, 209, 102, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.gc-quota-ico-img {
  width: 36rpx;
  height: 36rpx;
}

.gc-quota-text {
  flex: 1;
  min-width: 0;
}

.gc-quota-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #FFD166;
  letter-spacing: 0.4rpx;
}

.gc-quota-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 500;
  margin-top: 4rpx;
  letter-spacing: 0.2rpx;
  line-height: 1.4;
}

.gc-quota-em {
  color: #FFD166;
  font-weight: 800;
}

/* ── Subject chips · 横滑 (mockup line 67-70)
   bottom 定位 · 始终位于 consent 上方 · 避免与 consent 重叠 */
.gc-subjects {
  position: absolute;
  bottom: 810rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 26;
  white-space: nowrap;
}

.gc-sub {
  display: inline-block;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.75);
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
  margin-right: 16rpx;
}

.gc-sub-active {
  background: #fff;
  color: #0B0D12;
  border-color: #fff;
}

/* ── Consent card · 玻璃态 (mockup line 73-83) ─────────────────────────── */
.gc-consent {
  position: absolute;
  bottom: 520rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 25;
  padding: 28rpx;
  background: rgba(18, 21, 28, 0.85);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
}

.gc-consent-row {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.gc-consent-check {
  width: 44rpx;
  height: 44rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
}

.gc-consent-check.gc-consent-check-on {
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  border-color: transparent;
}

.gc-consent-check-img {
  width: 24rpx;
  height: 24rpx;
}

.gc-consent-tx {
  font-size: 23rpx;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: 0.2rpx;
  flex: 1;
}

.gc-consent-link {
  color: #4C9BFF;
  font-weight: 700;
}

.gc-consent-strong {
  color: #fff;
  font-weight: 700;
}

.gc-badge-row {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.gc-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
}

.gc-badge-green {
  background: rgba(60, 212, 123, 0.12);
  color: #3CD47B;
  border: 1rpx solid rgba(60, 212, 123, 0.25);
}

.gc-badge-blue {
  background: rgba(76, 155, 255, 0.12);
  color: #4C9BFF;
  border: 1rpx solid rgba(76, 155, 255, 0.25);
}

.gc-badge-orange {
  background: rgba(255, 180, 84, 0.12);
  color: #FFB454;
  border: 1rpx solid rgba(255, 180, 84, 0.25);
}

/* ── Controls dock · bottom (mockup line 86-96) ────────────────────────── */
.gc-controls {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  z-index: 30;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 44rpx;
}

.gc-sources {
  display: flex;
  gap: 72rpx;
  margin-bottom: 36rpx;
}

.gc-src {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: rgba(255, 255, 255, 0.75);
}

.gc-src-ico {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gc-src-ico-img {
  width: 36rpx;
  height: 36rpx;
}

.gc-src-lb {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.gc-shutter-row {
  display: flex;
  align-items: center;
  gap: 80rpx;
}

/* shutter wrap · 为外置 REC 徽标提供 position:relative 锚点 · overflow:visible */
.gc-shutter-wrap {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  overflow: visible;
}

.gc-shutter {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #fff;
  border: 8rpx solid rgba(255, 255, 255, 0.35);
  box-shadow:
    0 0 0 12rpx rgba(255, 255, 255, 0.08),
    0 36rpx 80rpx rgba(255, 255, 255, 0.25);
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.gc-shutter::after {
  border: none;
}

.gc-shutter-inner {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff, #e5e5ea);
}

.gc-shutter-disabled {
  opacity: 0.5;
}

.gc-shutter-rec {
  position: absolute;
  top: -28rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 1.2rpx;
  text-transform: uppercase;
  box-shadow: 0 8rpx 20rpx rgba(255, 59, 48, 0.4);
  white-space: nowrap;
}

.gc-sidebtn {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gc-sidebtn-icon {
  width: 36rpx;
  height: 36rpx;
}

/* ── ERROR banner ──────────────────────────────────────────────────────── */
.gc-error-banner {
  position: absolute;
  bottom: 880rpx;
  left: 36rpx;
  right: 36rpx;
  z-index: 40;
  padding: 20rpx 28rpx;
  background: rgba(255, 59, 48, 0.15);
  border: 2rpx solid rgba(255, 59, 48, 0.4);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.gc-error-text {
  flex: 1;
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: 600;
}

.gc-error-retry {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
  border: none;
  line-height: 1;
}

.gc-error-retry::after {
  border: none;
}

/* ── UPLOADING / ANALYZING overlay ─────────────────────────────────────── */
.gc-phase-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 50;
  padding: 36rpx 56rpx;
  background: rgba(11, 13, 18, 0.85);
  border: 2rpx solid rgba(76, 155, 255, 0.3);
  border-radius: 32rpx;
  text-align: center;
}

.gc-phase-spinner {
  font-size: 28rpx;
  font-weight: 800;
  color: #4C9BFF;
}

.gc-phase-progress {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ── READY block ───────────────────────────────────────────────────────── */
.gc-result {
  position: absolute;
  top: 50%;
  left: 36rpx;
  right: 36rpx;
  transform: translateY(-50%);
  z-index: 35;
  padding: 36rpx 28rpx;
  background: rgba(11, 13, 18, 0.92);
  border: 2rpx solid rgba(60, 212, 123, 0.3);
  border-radius: 32rpx;
}

.gc-result-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #3CD47B;
  margin-bottom: 20rpx;
  letter-spacing: 0.4rpx;
}

.gc-result-card {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
}

.gc-result-key {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.gc-result-val {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.gc-cta-save {
  margin-top: 20rpx;
  width: 100%;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
  letter-spacing: 0.4rpx;
}

.gc-cta-save::after {
  border: none;
}

/* ── QUOTA_EXHAUSTED full overlay ──────────────────────────────────────── */
.gc-quota-blocker {
  position: absolute;
  inset: 0;
  z-index: 100;
  background: rgba(11, 13, 18, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
}

.gc-quota-blocker-icon {
  font-size: 96rpx;
  margin-bottom: 20rpx;
}

.gc-quota-blocker-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
}

.gc-quota-blocker-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-align: center;
  margin-bottom: 24rpx;
}

.gc-quota-blocker-countdown {
  font-size: 28rpx;
  color: #FFD166;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.gc-quota-blocker-cta {
  padding: 24rpx 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4C9BFF, #8B87F6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border: none;
}

.gc-quota-blocker-cta::after {
  border: none;
}

/* 未勾同意时 shake 动画 (600ms · 双向晃 4 次) + 红框强调 */
.gc-consent-shake {
  animation: gc-shake 600ms cubic-bezier(.36,.07,.19,.97) both;
  border-color: #FF3B30 !important;
  box-shadow: 0 0 0 4rpx rgba(255, 59, 48, 0.25);
}

@keyframes gc-shake {
  10%, 90% { transform: translateX(-4rpx); }
  20%, 80% { transform: translateX(8rpx); }
  30%, 50%, 70% { transform: translateX(-12rpx); }
  40%, 60% { transform: translateX(12rpx); }
}
