/* P00 login · MP · 沿 design/mockups/wrongbook/00_login.html 简化版
 * 移动端居中卡片 + 蓝紫主色 (#7B6FE8)
 */

.root {
  min-height: 100vh;
  padding: 80rpx 48rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f7f5ff 0%, #ffffff 100%);
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
  margin-bottom: 56rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #7B6FE8, #6155cd);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  box-shadow: 0 12rpx 32rpx rgba(123, 111, 232, 0.32);
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-top: 28rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  margin-top: 12rpx;
}

.card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field {
  background: #fff;
  border: 2rpx solid #e5e5ea;
  border-radius: 16rpx;
  padding: 0 32rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  transition: border-color 0.2s ease;
}

.field-error {
  border-color: #ff3b30;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1c1c1e;
  height: 100%;
}

.error-banner {
  background: #ffeceb;
  color: #d70015;
  font-size: 26rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff3b30;
}

.login-cta {
  margin-top: 8rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #7B6FE8, #6155cd);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  line-height: 96rpx;
  box-shadow: 0 12rpx 24rpx rgba(123, 111, 232, 0.28);
}

.login-cta.is-loading {
  opacity: 0.6;
}

.divider {
  display: flex;
  align-items: center;
  margin: 56rpx 0 32rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: #e5e5ea;
}

.divider-text {
  margin: 0 24rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.wechat-cta {
  height: 96rpx;
  background: #fff;
  color: #07c160;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #07c160;
  border-radius: 16rpx;
  line-height: 92rpx;
}

.foot {
  margin-top: auto;
  padding-top: 48rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8e8e93;
}

.foot-text {
  color: #8e8e93;
}

.foot-link {
  color: #7B6FE8;
  margin: 0 6rpx;
}
