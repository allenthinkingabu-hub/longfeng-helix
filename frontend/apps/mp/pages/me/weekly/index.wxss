/* P-WEEKLY-REVIEW · 本周回顾详情页 (SC-16-T02) */
/* trace: design/mockups/wrongbook/14_weekly_review.html (canonical · 462 行) */

page {
  background: #F6F3EC;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  color: #1C1C1E;
}

.weekly-page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ── A11Y · sr-only · visually-hidden 文本节点 (spec §3 DeltaChip srText) ─ */
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

/* ── Topbar ──────────────────────────────────────────── */
.topbar {
  position: sticky;
  top: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(246, 243, 236, 0.92);
  backdrop-filter: blur(20rpx);
}

.back, .share {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(60, 60, 67, 0.12);
}

.titlecol {
  flex: 1;
  text-align: center;
}

.titlecol .t {
  font-size: 30rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.4rpx;
  display: block;
}

.titlecol .s {
  font-size: 22rpx;
  font-weight: 600;
  color: #8E8E93;
  margin-top: 4rpx;
  display: block;
}

/* ── ERROR banner (顶部黄条 · §9 TC-3) ────────────── */
.error-banner {
  margin: 32rpx;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #FFF4E6 0%, #FFE5C4 100%);
  border: 1rpx solid rgba(255, 149, 0, 0.32);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.error-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #C84B00;
}

.error-sub {
  font-size: 24rpx;
  color: #8B4A1A;
}

.retry-btn {
  margin-top: 12rpx;
  align-self: flex-start;
  padding: 16rpx 40rpx;
  background: linear-gradient(180deg, #FF9500, #E07800);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 149, 0, 0.25);
}

/* ── EMPTY hero (§9 TC-4) ──────────────────────────── */
.empty-hero {
  margin: 80rpx 32rpx;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 36rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1C1C1E;
  margin-bottom: 16rpx;
  letter-spacing: -0.6rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #636366;
  line-height: 1.55;
  margin-bottom: 40rpx;
}

.empty-cta {
  display: inline-block;
  padding: 24rpx 56rpx;
  background: linear-gradient(180deg, #007AFF, #0062E1);
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 122, 255, 0.30);
}

/* ── LOADING skeleton ────────────────────────────────── */
.skeleton {
  padding: 32rpx;
}

.skeleton-card {
  background: rgba(120, 120, 128, 0.12);
  border-radius: 36rpx;
  margin-bottom: 24rpx;
}

.skeleton-hero { height: 320rpx; }
.skeleton-radar { height: 280rpx; }
.skeleton-weakkp { height: 360rpx; }
.skeleton-stat { height: 160rpx; }
.skeleton-failed { height: 180rpx; }
.skeleton-insight { height: 200rpx; }

/* ── HERO 暗卡 ─────────────────────────────────────── */
.hero {
  margin: 24rpx 32rpx;
  padding: 48rpx 40rpx;
  background: linear-gradient(135deg, #0E0E10 0%, #1A1A1F 60%, #2A2030 100%);
  border-radius: 44rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 56rpx rgba(14, 14, 16, 0.30);
  /* §6 顺序淡入 Hero 0ms */
  animation: fadeIn 280ms ease-out forwards;
}

.hero-kicker {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2.4rpx;
  color: rgba(255, 255, 255, 0.55);
  text-transform: uppercase;
  margin-bottom: 24rpx;
}

.hero-display {
  display: flex;
  align-items: baseline;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.hero-num {
  font-size: 110rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
  line-height: 1;
  color: #FDBA74;
  font-style: italic;
}

.delta-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  position: relative;
}

.delta-chip-up {
  background: rgba(52, 199, 89, 0.20);
  color: #6DE895;
  border: 1rpx solid rgba(52, 199, 89, 0.45);
}

.delta-chip-down {
  background: rgba(255, 59, 48, 0.20);
  color: #FF6961;
  border: 1rpx solid rgba(255, 59, 48, 0.45);
}

.delta-chip-flat {
  background: rgba(142, 142, 147, 0.20);
  color: #C7C7CC;
  border: 1rpx solid rgba(142, 142, 147, 0.45);
}

.delta-arrow {
  font-size: 22rpx;
}

.delta-unit {
  font-size: 18rpx;
  font-weight: 600;
  margin-left: 4rpx;
  opacity: 0.85;
}

.hero-sub {
  font-size: 24rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.62);
  margin-bottom: 24rpx;
}

.hero-spark {
  height: 54rpx;
  width: 100%;
}

.hero-spark-svg {
  width: 100%;
  height: 100%;
  display: block;
}

/* ── Section title ───────────────────────────────────── */
.sec {
  margin: 36rpx 40rpx 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.sec-t {
  font-size: 28rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.2rpx;
}

.sec-m {
  font-size: 22rpx;
  color: #007AFF;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

/* ── Subject Radar Card ──────────────────────────────── */
.radar-card {
  margin: 0 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 36rpx;
  display: flex;
  gap: 32rpx;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  /* §6 Radar 100ms */
  animation: fadeIn 280ms ease-out 100ms backwards;
}

.radar-svg {
  width: 220rpx;
  height: 220rpx;
  flex: none;
}

.radar-legend {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.radar-legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
}

.radar-legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex: none;
}

.radar-legend-name {
  flex: 1;
  color: #1C1C1E;
  font-weight: 600;
}

.radar-legend-rate {
  color: #636366;
  font-weight: 800;
}

/* ── Weak KP top 3 ──────────────────────────────────── */
.weakcol {
  margin: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  /* §6 KP 200ms */
  animation: fadeIn 280ms ease-out 200ms backwards;
}

.wkp {
  padding: 28rpx 32rpx;
  border-radius: 32rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.wkp-highlight {
  background: linear-gradient(135deg, #FFE7CC 0%, #FFD09E 100%);
  border: 1rpx solid rgba(252, 145, 0, 0.32);
}

.wkp-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.wkp-rank {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(28, 28, 30, 0.85);
  color: #fff;
  font-weight: 800;
  font-size: 22rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.wkp-name {
  font-size: 28rpx;
  font-weight: 800;
  color: #1C1C1E;
  letter-spacing: -0.2rpx;
}

.wkp-meta {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.wkp-subject, .wkp-miss {
  font-size: 22rpx;
  color: #636366;
}

.wkp-miss {
  color: #C84B00;
  font-weight: 700;
}

.wkp-cta {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.wkp-cta-primary {
  background: linear-gradient(180deg, #0E0E10, #2A2030);
  color: #fff;
}

.wkp-cta-outline {
  background: transparent;
  color: #1C1C1E;
  border: 1rpx solid rgba(60, 60, 67, 0.32);
}

/* ── Stat trio ──────────────────────────────────────── */
.stat3 {
  margin: 0 32rpx;
  padding: 28rpx 32rpx;
  background: #fff;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  /* §6 stat 300ms */
  animation: fadeIn 280ms ease-out 300ms backwards;
}

.stat3-item {
  flex: 1;
  text-align: center;
}

.stat3-n {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -0.4rpx;
  line-height: 1;
  display: block;
}

.stat3-l {
  font-size: 20rpx;
  font-weight: 700;
  color: #8E8E93;
  letter-spacing: 1.2rpx;
  margin-top: 8rpx;
  text-transform: uppercase;
  display: block;
}

.stat-green { color: #34C759; }
.stat-blue { color: #007AFF; }
.stat-orange { color: #FF9500; }

.stat3-sep {
  flex: none;
  width: 2rpx;
  height: 64rpx;
  background: rgba(60, 60, 67, 0.14);
}

/* ── Failed scroller ────────────────────────────────── */
.failscroller {
  margin: 0 32rpx;
  white-space: nowrap;
  /* §6 Failed 400ms */
  animation: fadeIn 280ms ease-out 400ms backwards;
}

.fcard {
  display: inline-flex;
  flex-direction: column;
  width: 240rpx;
  margin-right: 16rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  vertical-align: top;
}

.fcard-thumb {
  width: 200rpx;
  height: 120rpx;
  background: rgba(120, 120, 128, 0.12);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.fcard-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
}

.fcard-subject {
  color: #1C1C1E;
  font-weight: 700;
}

.fcard-miss {
  color: #C84B00;
  font-weight: 700;
}

/* ── AI insight 暗卡 ───────────────────────────────── */
.insight {
  margin: 16rpx 32rpx 0;
  padding: 32rpx 40rpx;
  background: linear-gradient(135deg, #0E0E10 0%, #1A1A1F 60%, #2A2030 100%);
  border-radius: 36rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 56rpx rgba(14, 14, 16, 0.30);
  /* §6 Insight 500ms */
  animation: fadeIn 280ms ease-out 500ms backwards;
}

.insight-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.insight-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FDBA74;
  animation: pulse 1.4s ease-in-out infinite;
}

.insight-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1.6rpx;
  color: rgba(255, 255, 255, 0.55);
  text-transform: uppercase;
}

.insight-body {
  font-size: 28rpx;
  line-height: 1.55;
  font-weight: 600;
}

.insight-text {
  display: block;
  margin-bottom: 12rpx;
}

.insight-meta {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  font-weight: 500;
}

.insight-loading .insight-text {
  color: rgba(255, 255, 255, 0.55);
  font-style: italic;
}

/* ── 动画 ───────────────────────────────────────────── */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.55; transform: scale(0.85); }
}
