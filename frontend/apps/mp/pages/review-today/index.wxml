<!-- P07 今日复习 · 1:1 mirror of design/mockups/wrongbook/07_review_today.html -->
<!-- trace: design/mockups/wrongbook/07_review_today.html · @longfeng/testids p07 -->

<view class="review-today-page" data-test-id="p07-root">

  <!-- ── Nav bar (mockup .nav) ───────────────────────── -->
  <view class="nav">
    <view class="nav-row">
      <view class="back" bind:tap="onBackTap">
        <van-icon name="arrow-left" color="#007AFF" size="20px" />
        <text>首页</text>
      </view>
      <!-- P07-D · 排序 chip 可点 · ActionSheet 出 3 选项 (时间/T级/学科) ·
           之前是死字符串 "排序 · 时间" 点了无反应 · 现 sortLabel 跟 mode 实时换 -->
      <view class="nav-right" bind:tap="onSortTap" data-test-id="p07-sort-chip">
        <text>排序 · {{sortLabel}}</text>
      </view>
    </view>
    <text class="nav-title">今日复习</text>
  </view>

  <!-- ── Content scroll area ─────────────────────────── -->
  <scroll-view class="content" scroll-y="true">

    <!-- ── Hero summary card ───────────────────────── -->
    <view class="hero" data-test-id="today-review-card">
      <view class="bubble b1" data-test-id="today-review-card-particles"></view>
      <view class="bubble b2"></view>

      <view class="hero-tag">
        <view class="live-dot"></view>
        <text>{{dateStr}} · {{weekday}} · GMT+8</text>
      </view>

      <view class="hero-h2">
        <text class="hero-total" data-test-id="today-review-card-total">{{totalCount}} 题待复习</text>
        <text class="hero-sz" data-test-id="today-review-card-est-min">预计 {{estMinutes}} 分钟</text>
      </view>

      <view class="stats-row">
        <view class="st">
          <text class="st-v" data-test-id="today-review-card-done">{{doneCount}}</text>
          <text class="st-l">已完成</text>
        </view>
        <view class="st">
          <text class="st-v">{{inProgressCount}}</text>
          <text class="st-l">进行中</text>
        </view>
        <view class="st">
          <text class="st-v">{{waitCount}}</text>
          <text class="st-l">未开始</text>
        </view>
      </view>

      <view class="pg" data-test-id="today-review-card-progress-bar">
        <view class="pg-fill" style="width: {{progressPct}}%;"></view>
      </view>
      <view class="pg-txt">
        <text data-test-id="p07-hero-progress-pct">进度 {{progressPct}}%</text>
        <text data-test-id="today-review-card-mastery-pct">掌握度 {{masteryPct}}%</text>
      </view>
    </view>

    <!-- ── Empty state ─────────────────────────────── -->
    <view wx:if="{{pageState === 'today.EMPTY'}}" class="empty" data-test-id="p07-empty-state">
      <text class="empty-title">今日无题 · 拍一道试试</text>
      <text class="empty-sub">还没有待复习的题目</text>
    </view>

    <!-- ── ALL_DONE 庆祝 banner (spec §6 状态机 "庆祝升级态") ──
         今日 N 题全部 GRADED → 出庆祝 + 卡片仍渲染 (用户能复看哪几道) -->
    <view wx:if="{{pageState === 'today.ALL_DONE'}}" class="all-done-banner" data-test-id="p07-all-done-banner">
      <text class="all-done-emoji">🎉</text>
      <view>
        <view class="all-done-title">今日复习全部完成</view>
        <view class="all-done-sub">{{totalCount}} 题 · 掌握度 {{masteryPct}}%</view>
      </view>
    </view>

    <!-- ── Slot groups (LIST + ALL_DONE 都渲染 · 之前仅 LIST · ALL_DONE 态卡片消失变白屏) -->
    <block wx:if="{{pageState === 'today.LIST' || pageState === 'today.ALL_DONE'}}" wx:for="{{slots}}" wx:key="key">
      <view class="slot">
        <view class="slot-icon {{item.iconClass}}">
          <van-icon wx:if="{{item.key === 'now'}}" name="clock-o" size="12px" />
          <van-icon wx:elif="{{item.key === 'afternoon'}}" name="fire-o" size="12px" />
          <van-icon wx:else name="star-o" size="12px" />
        </view>
        <text class="slot-title">{{item.title}}</text>
        <view class="slot-line"></view>
        <text class="slot-count">{{item.items.length}} 题</text>
      </view>

      <view wx:for="{{item.items}}" wx:for-item="card" wx:key="nid" class="it {{card.sideColor}}" bind:tap="onItemTap" data-nid="{{card.nid}}">
        <view class="side"></view>
        <view class="tc">
          <text class="hh">{{card.hhmm}}</text>
          <text class="lv">{{card.tLevel}}</text>
        </view>
        <view class="body">
          <view class="body-h">
            <text class="sub {{card.sideColor}}">{{card.subject}}</text>
            <text> · {{card.kp}}</text>
          </view>
          <text class="stem">{{card.stem}}</text>
          <view class="tags">
            <!-- Progress chip · 与 hero "已完成/进行中/未开始" 计数对齐 · 一眼分清哪条是哪条 -->
            <text class="tg-prog tg-prog-{{card.progress}}">{{card.progressLabel}}</text>
            <text wx:for="{{card.tags}}" wx:for-item="tag" wx:key="*this" class="tg {{tag[0] === '★' ? 'tg-m' : ''}}">{{tag}}</text>
          </view>
        </view>
        <view class="right">
          <text class="cd {{card.countdownState === 'now' ? 'cd-now' : card.countdownState === 'soon' ? 'cd-soon' : 'cd-wait'}}">{{card.countdownLabel}}</text>
          <view class="arrow">
            <van-icon name="arrow" color="#C7C7CC" size="13px" />
          </view>
        </view>
      </view>
    </block>

    <!-- bottom spacer for CTA -->
    <view style="height: 140rpx;"></view>
  </scroll-view>

  <!-- ── Floating CTA · LIST 态 · 全部开始 ── -->
  <view wx:if="{{pageState === 'today.LIST'}}" class="cta" bind:tap="onStartAllTap" data-test-id="p07-bottom-cta-start-all-btn">
    <van-icon name="play" color="#fff" size="20px" />
    <text>全部开始</text>
    <text class="cta-sz">{{totalCount}} 题 · {{estMinutes}} min</text>
  </view>

  <!-- ── ALL_DONE CTA · 跳回首页 (spec §6 状态机 ALL_DONE → 跳 P-HOME) ── -->
  <view wx:if="{{pageState === 'today.ALL_DONE'}}" class="cta cta--done" bind:tap="onBackHome" data-test-id="p07-all-done-cta">
    <van-icon name="success" color="#fff" size="20px" />
    <text>回到首页</text>
    <text class="cta-sz">今日全部完成</text>
  </view>

</view>
