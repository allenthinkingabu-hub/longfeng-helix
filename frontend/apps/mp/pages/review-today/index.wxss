/* P07 今日复习 · 1:1 mirror of design/mockups/wrongbook/07_review_today.html */
/* trace: design/mockups/wrongbook/07_review_today.html */

page {
  background: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  color: #1C1C1E;
}

.review-today-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Nav ────────────────────────────────────────────── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 12rpx 36rpx 20rpx;
  background: rgba(242,242,247,0.78);
  backdrop-filter: blur(22px) saturate(180%);
  border-bottom: 1rpx solid rgba(60,60,67,0.14);
  z-index: 20;
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72rpx;
}

.back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #007AFF;
  font-size: 34rpx;
}

.nav-right {
  color: #007AFF;
  font-size: 30rpx;
  font-weight: 600;
}

.nav-title {
  font-size: 68rpx;
  font-weight: 700;
  letter-spacing: 0.72rpx;
  display: block;
  margin-top: 4rpx;
}

/* ── Content ────────────────────────────────────────── */
.content {
  flex: 1;
  margin-top: 240rpx;
  padding: 24rpx 32rpx 32rpx;
  height: calc(100vh - 240rpx);
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ── Hero summary card ──────────────────────────────── */
.hero {
  position: relative;
  background: linear-gradient(160deg, #0F1A3D 0%, #1F3C8C 50%, #5F5BDB 100%);
  border-radius: 40rpx;
  padding: 32rpx;
  color: #fff;
  overflow: hidden;
  box-shadow: 0 40rpx 80rpx rgba(30,40,120,0.28);
}

.bubble {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.10);
}

.b1 { width: 320rpx; height: 320rpx; top: -120rpx; right: -80rpx; }
.b2 { width: 200rpx; height: 200rpx; bottom: -60rpx; left: -60rpx; }

.hero-tag {
  font-size: 24rpx;
  letter-spacing: 1.2rpx;
  text-transform: uppercase;
  font-weight: 600;
  opacity: 0.85;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.live-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFCC00;
  box-shadow: 0 0 0 8rpx rgba(255,204,0,0.28);
}

.hero-h2 {
  margin-top: 8rpx;
  display: flex;
  align-items: baseline;
  gap: 20rpx;
}

.hero-total {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
}

.hero-sz {
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0.85;
}

.stats-row {
  margin-top: 28rpx;
  display: flex;
  gap: 20rpx;
}

.st {
  flex: 1;
  background: rgba(255,255,255,0.10);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,0.14);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
}

.st-v {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  display: block;
}

.st-l {
  font-size: 22rpx;
  opacity: 0.75;
  letter-spacing: 0.6rpx;
  display: block;
}

/* progress */
.pg {
  margin-top: 24rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.18);
  overflow: hidden;
  position: relative;
}

.pg-fill {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #FFCC00, #FFB0C4, #FFFFFF);
}

.pg-txt {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 22rpx;
  opacity: 0.8;
}

/* ── Empty state ────────────────────────────────────── */
.empty {
  text-align: center;
  padding: 80rpx 0;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1C1C1E;
  display: block;
}

.empty-sub {
  font-size: 26rpx;
  color: #8E8E93;
  margin-top: 12rpx;
  display: block;
}

/* ── Time slot label ────────────────────────────────── */
.slot {
  margin: 32rpx 8rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.slot-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 44rpx;
}

.slotIconYellow { background: #FFCC00; color: #7a3b3b; }
.slotIconBlue { background: rgba(0,122,255,0.14); color: #007AFF; }
.slotIconIndigo { background: rgba(88,86,214,0.14); color: #5856D6; }

.slot-title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.slot-line {
  flex: 1;
  height: 2rpx;
  background: rgba(60,60,67,0.14);
  margin: 0 8rpx;
}

.slot-count {
  font-size: 24rpx;
  color: #8E8E93;
  font-weight: 600;
}

/* ── Item card ──────────────────────────────────────── */
.it {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 0 rgba(0,0,0,0.03), 0 16rpx 44rpx rgba(40,50,90,0.05);
  position: relative;
  overflow: hidden;
}

.side {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
}

.it.red .side { background: #FF3B30; }
.it.orange .side { background: #FF9500; }
.it.blue .side { background: #007AFF; }
.it.indigo .side { background: #5856D6; }
.it.green .side { background: #34C759; }

.tc {
  flex: 0 0 116rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-right: 1rpx solid rgba(60,60,67,0.14);
  padding-right: 16rpx;
}

.hh {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  color: #1C1C1E;
}

.lv {
  font-size: 20rpx;
  font-weight: 700;
  color: #007AFF;
  letter-spacing: 0.8rpx;
  background: rgba(0,122,255,0.10);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.body {
  flex: 1;
  min-width: 0;
}

.body-h {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  text-transform: uppercase;
}

.sub { color: #007AFF; }
.sub.red { color: #007AFF; }
.sub.orange { color: #FF9500; }
.sub.indigo { color: #5856D6; }
.sub.green { color: #34C759; }

.stem {
  font-size: 27rpx;
  line-height: 1.45;
  margin-top: 6rpx;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tags {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.tg {
  display: inline-flex;
  gap: 8rpx;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(88,86,214,0.08);
  color: #5856D6;
  border: 1rpx solid rgba(88,86,214,0.18);
}

.tg-m {
  background: rgba(255,149,0,0.1);
  color: #FF9500;
  border-color: rgba(255,149,0,0.22);
}

/* Progress chip · 三态颜色对齐 hero 计数语义 (done=绿/进行中=蓝/未开始=灰)
   独立 .tg-prog 类避免被通用 .tg (紫色) 遮盖 · 与 ★ tag .tg-m (橙) 区分 */
.tg-prog {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  border: 1rpx solid transparent;
}

.tg-prog-done {
  background: rgba(52,199,89,0.12);
  color: #34C759;
  border-color: rgba(52,199,89,0.24);
}

.tg-prog-inprogress {
  background: rgba(0,122,255,0.12);
  color: #007AFF;
  border-color: rgba(0,122,255,0.24);
}

.tg-prog-wait {
  background: #F2F2F7;
  color: #8E8E93;
  border-color: rgba(60,60,67,0.18);
}

.right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex: 0 0 120rpx;
}

.cd {
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  letter-spacing: 0.4rpx;
}

.cd-now { background: #FF3B30; color: #fff; }
.cd-soon { background: rgba(255,149,0,0.15); color: #FF9500; }
.cd-wait { background: #F2F2F7; color: #8E8E93; }

.arrow { color: #C7C7CC; }

/* ── Floating CTA ───────────────────────────────────── */
.cta {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  height: 108rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #5FA8FF, #007AFF);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 32rpx 68rpx rgba(0,122,255,0.32), 0 8rpx 24rpx rgba(0,122,255,0.22);
  z-index: 15;
}

.cta-sz {
  font-size: 26rpx;
  font-weight: 600;
  opacity: 0.9;
  background: rgba(255,255,255,0.2);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

