/* P08 复习执行 · 1:1 mirror of design/mockups/wrongbook/08_review_exec.html */
/* trace: design/mockups/wrongbook/08_review_exec.html */

page {
  background: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  color: #1C1C1E;
}

.review-exec-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Nav ────────────────────────────────────────────── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 192rpx;
  padding: 16rpx 32rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 30;
  background: rgba(242,242,247,0.82);
  backdrop-filter: blur(22px) saturate(180%);
  border-bottom: 1rpx solid rgba(60,60,67,0.14);
}

.back {
  display: flex;
  align-items: center;
  gap: 4rpx;
  color: #007AFF;
  font-size: 34rpx;
}

.center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.2rpx;
}

.sub {
  font-size: 22rpx;
  color: #636366;
  letter-spacing: 0.4rpx;
}

.close {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(120,120,128,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* progress track */
.ptrack {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 16rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(120,120,128,0.18);
  overflow: hidden;
}

.pbar {
  height: 100%;
  background: linear-gradient(90deg, #34C759, #007AFF);
  border-radius: 4rpx;
}

.plbl {
  position: absolute;
  right: 0;
  top: -32rpx;
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

/* ── Scroll area ────────────────────────────────────── */
.scroll {
  flex: 1;
  margin-top: 192rpx;
  padding: 28rpx 32rpx 400rpx;
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ── Meta chips ─────────────────────────────────────── */
.metarow {
  display: flex;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 500;
  flex-wrap: wrap;
  min-width: 0;
}

.chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(120,120,128,0.12);
  color: #8E8E93;
  font-weight: 600;
  font-size: 22rpx;
  letter-spacing: 0.4rpx;
}

.chip-red {
  background: rgba(255,59,48,0.12);
  color: #FF3B30;
}

.chip-indigo {
  background: rgba(88,86,214,0.12);
  color: #5856D6;
}

.chip-orange {
  background: rgba(255,149,0,0.14);
  color: #FF9500;
}

.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

/* ── Question card ──────────────────────────────────── */
.qcard {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

.qkicker {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.2rpx;
  color: #5856D6;
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.qstem {
  font-size: 32rpx;
  line-height: 1.55;
  color: #1C1C1E;
  letter-spacing: 0.2rpx;
}

.qmeta {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(60,60,67,0.14);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 600;
}

.stars {
  color: #FF9500;
  letter-spacing: 2rpx;
}

/* ── Block title ────────────────────────────────────── */
.block-title {
  margin: 32rpx 4rpx 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #8E8E93;
  letter-spacing: 2.4rpx;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.block-title-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #007AFF;
}

.block-title-green {
  color: #1E7F3C;
}

.block-title-dot-green {
  background: #34C759;
}

/* ── Work area ──────────────────────────────────────── */
.work {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

.paper {
  border-radius: 24rpx;
  background: repeating-linear-gradient(180deg, #FCFCFE 0, #FCFCFE 54rpx, rgba(88,86,214,0.08) 54rpx, rgba(88,86,214,0.08) 56rpx);
  border: 2rpx solid rgba(120,120,128,0.16);
  padding: 24rpx 28rpx;
  min-height: 248rpx;
}

.handwritten {
  font-size: 40rpx;
  color: #1F4FD6;
  line-height: 1.65;
  letter-spacing: 0.6rpx;
}

.cursor-blink {
  display: inline-block;
  width: 4rpx;
  height: 36rpx;
  background: #1F4FD6;
  vertical-align: -6rpx;
  margin-left: 4rpx;
  animation: blink 1s steps(1) infinite;
}

@keyframes blink {
  50% { opacity: 0; }
}

.tools {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.tool {
  flex: 1;
  height: 68rpx;
  border-radius: 20rpx;
  background: rgba(120,120,128,0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #636366;
}

.tool-prime {
  background: rgba(0,122,255,0.12);
  color: #007AFF;
}

/* ── Keyboard / Formula input modes ─────────────────── */
.paper-input {
  background: #FCFCFE;
  border-radius: 24rpx;
  border: 2rpx solid rgba(120,120,128,0.16);
  padding: 24rpx 28rpx;
  min-height: 248rpx;
}

.kb-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 32rpx;
  line-height: 1.55;
  color: #1C1C1E;
  letter-spacing: 0.2rpx;
}

.fm-display {
  min-height: 96rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(120,120,128,0.06);
  font-size: 32rpx;
  line-height: 1.55;
  color: #1F4FD6;
  letter-spacing: 0.4rpx;
  word-break: break-all;
}

.fm-placeholder {
  color: #8E8E93;
  font-size: 26rpx;
  font-style: italic;
}

.fm-keypad {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
}

.fm-key {
  height: 72rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid rgba(120,120,128,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

.fm-key:active {
  background: rgba(0,122,255,0.08);
  border-color: rgba(0,122,255,0.3);
}

.fm-key-util {
  background: rgba(120,120,128,0.10);
  color: #636366;
  font-size: 24rpx;
}

/* ── Reveal button ──────────────────────────────────── */
.reveal-btn-wrap {
  margin: 24rpx 0;
}

/* ── Reveal content ─────────────────────────────────── */
.reveal {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
  margin-top: 28rpx;
}

.reveal-hidden {
  display: none;
}

.reveal-visible {
  display: block;
}

.reveal-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 16rpx;
}

.reveal-head-l {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reveal-ico {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #34C759, #2AA84A);
  display: flex;
  align-items: center;
  justify-content: center;
}

.reveal-ttl {
  font-size: 28rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.reveal-sub {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

.ans {
  margin: 8rpx 28rpx 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(52,199,89,0.10), rgba(52,199,89,0.04));
  border: 2rpx solid rgba(52,199,89,0.22);
}

.ans-k {
  font-size: 22rpx;
  font-weight: 700;
  color: #1E7F3C;
  letter-spacing: 0.8rpx;
  margin-bottom: 4rpx;
}

.ans-v {
  font-size: 32rpx;
  font-style: italic;
  color: #0B5A2A;
  letter-spacing: 0.4rpx;
}

.steps {
  padding: 8rpx 28rpx 28rpx;
}

.stp {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
}

.stp-n {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #5856D6;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
}

.stp-t {
  font-size: 26rpx;
  line-height: 1.5;
  color: #1C1C1E;
}

/* ── Node timeline ──────────────────────────────────── */
.nodes {
  margin: 28rpx 0 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.8rpx;
  min-width: 0;
}

.node-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(120,120,128,0.22);
}

.node-dot-done {
  background: #34C759;
  box-shadow: 0 0 0 4rpx rgba(52,199,89,0.18);
}

.node-dot-now {
  background: linear-gradient(135deg, #5AA3FF, #0062E1);
  box-shadow: 0 0 0 6rpx rgba(0,122,255,0.25);
}

.node-dot-pulse {
  animation: pulse 1.5s ease infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.node-line {
  flex: 1;
  height: 4rpx;
  background: rgba(120,120,128,0.22);
  border-radius: 4rpx;
}

.node-line-green {
  background: #34C759;
}

.node-label {
  margin-left: auto;
}

/* ── Rating bar (fixed bottom) ──────────────────────── */
.rating {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(242,242,247,0.88);
  backdrop-filter: blur(22px) saturate(180%);
  border-top: 1rpx solid rgba(60,60,67,0.14);
  z-index: 20;
}

.rtitle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.rtitle-l {
  font-size: 26rpx;
  font-weight: 700;
  color: #1C1C1E;
  letter-spacing: 0.2rpx;
}

.rtitle-r {
  font-size: 22rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

.ractions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
}

.rbtn {
  height: 120rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.rbtn-disabled {
  opacity: 0.4;
  pointer-events: none;
}

.ri {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
}

.rl {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.rs {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.6rpx;
  opacity: 0.8;
}

.rbtn-forgot {
  background: linear-gradient(180deg, rgba(255,59,48,0.08), rgba(255,59,48,0.16));
  color: #FF3B30;
  border: 2rpx solid rgba(255,59,48,0.2);
}

.ri-red {
  background: #FF3B30;
}

.rbtn-partial {
  background: linear-gradient(180deg, rgba(255,149,0,0.08), rgba(255,149,0,0.16));
  color: #FF9500;
  border: 2rpx solid rgba(255,149,0,0.2);
}

.ri-orange {
  background: #FF9500;
}

.rbtn-master {
  background: linear-gradient(180deg, rgba(52,199,89,0.10), rgba(52,199,89,0.22));
  color: #1E7F3C;
  border: 2rpx solid rgba(52,199,89,0.28);
  box-shadow: 0 4rpx 16rpx rgba(52,199,89,0.16);
}

.ri-green {
  background: #34C759;
}

/* ── Exit confirm sheet ─────────────────────────────── */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
}

.sheet {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1C1C1E;
  text-align: center;
  margin-bottom: 16rpx;
}

.sheet-body {
  font-size: 28rpx;
  color: #636366;
  text-align: center;
  margin-bottom: 40rpx;
}

.sheet-actions {
  display: flex;
  gap: 20rpx;
}

.sheet-actions van-button {
  flex: 1;
}
