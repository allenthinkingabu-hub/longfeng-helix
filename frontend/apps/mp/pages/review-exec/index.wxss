/* ── Node timeline ──────────────────────────────────── */
.nodes {
  margin: 28rpx 0 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.8rpx;
