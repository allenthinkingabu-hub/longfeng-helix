<!-- P08 复习执行 · 1:1 mirror of design/mockups/wrongbook/08_review_exec.html -->
<!-- trace: design/mockups/wrongbook/08_review_exec.html · @longfeng/testids p08 -->

<view class="review-exec-page" data-test-id="p08-root">

  <!-- ── Nav (mockup .nav) ──────────────────────────────── -->
  <view class="nav" data-test-id="p08-topbar">
    <view class="back" bind:tap="onBackTap">
      <van-icon name="arrow-left" color="#007AFF" size="22px" />
      <text>复习</text>
    </view>
    <view class="center">
      <text class="title" data-test-id="p08-topbar-cursor">复习执行 · 第 {{cursor}} 题</text>
      <text class="sub">{{cursor}} / {{total}} · 剩余 {{total - cursor}} 题</text>
    </view>
    <view class="close" bind:tap="onCloseTap" data-test-id="p08-close-btn">
      <van-icon name="cross" color="#636366" size="14px" />
    </view>
    <view class="ptrack" data-test-id="p08-progress-bar">
      <text class="plbl">{{progressPct}}% · 预计 6 分钟</text>
      <view class="pbar" style="width: {{progressPct}}%;"></view>
    </view>
  </view>

  <!-- ── Scroll area ──────────────────────────────────── -->
  <scroll-view class="scroll" scroll-y="true">

    <!-- ── Meta chips ─────────────────────────────────── -->
    <view class="metarow" data-test-id="p08-meta-chips">
      <view class="chip chip-red">
        <view class="dot"></view>
        <text>{{node.tLevel}} · 第 {{node.nodeIndex + 1}} 次复习</text>
      </view>
      <view class="chip chip-indigo">
        <text>{{question.subject}} · {{question.kpName}}</text>
      </view>
      <view class="chip chip-orange">
        <text>{{difficultyLabel}} {{starsLabel}}</text>
      </view>
    </view>

    <!-- ── Question card ──────────────────────────────── -->
    <view class="qcard" data-test-id="p08-question-hero">
      <text class="qkicker">错题回顾 · 原题</text>
      <view class="qstem">
        <text>{{question.stem}}</text>
      </view>
      <view class="qmeta">
        <text>知识点 · 顶点式 · 配方法</text>
        <text class="stars">{{starsLabel}}</text>
      </view>
    </view>

    <!-- ── Work area ──────────────────────────────────── -->
    <view class="block-title">
      <view class="block-title-dot"></view>
      <text>你的解答 · 手写</text>
    </view>
    <view class="work" data-test-id="p08-answer-area" bind:touchstart="onCanvasTouch">
      <!-- ── Mode: handwrite (paper · 手写笔迹 demo · canvas 后续接入) ── -->
      <view wx:if="{{answerMode === 'handwrite'}}" class="paper">
        <view class="handwritten">
          <text>f(x) = x² − 4x + 3\n      = (x² − 4x + 4) − 4 + 3\n      = (x − 2)² − 1\n∴ 顶点 (2, −1)</text>
          <view class="cursor-blink"></view>
        </view>
      </view>

      <!-- ── Mode: keyboard (textarea 输入) ── -->
      <view wx:elif="{{answerMode === 'keyboard'}}" class="paper paper-input" catch:touchstart="onCanvasTouch">
        <textarea
          class="kb-input"
          placeholder="在此输入你的解答…"
          value="{{userAnswer}}"
          bindinput="onKeyboardInput"
          maxlength="-1"
          auto-height
          adjust-position="{{false}}"
          data-test-id="p08-answer-keyboard"
        />
      </view>

      <!-- ── Mode: formula (符号面板) ── -->
      <view wx:else class="paper paper-input">
        <view class="fm-display" data-test-id="p08-answer-formula-display">
          <text wx:if="{{userAnswer}}">{{userAnswer}}</text>
          <text wx:else class="fm-placeholder">点下方符号拼接你的解答…</text>
        </view>
        <view class="fm-keypad" data-test-id="p08-answer-formula-keypad">
          <view
            wx:for="{{formulaSymbols}}"
            wx:key="*this"
            class="fm-key"
            data-sym="{{item}}"
            bind:tap="onFormulaInsert"
          >{{item}}</view>
          <view class="fm-key fm-key-util" bind:tap="onFormulaBackspace">⌫</view>
          <view class="fm-key fm-key-util" bind:tap="onFormulaClear">清空</view>
        </view>
      </view>

      <view class="tools">
        <view
          class="tool {{answerMode === 'handwrite' ? 'tool-prime' : ''}}"
          data-mode="handwrite"
          data-test-id="p08-tool-handwrite"
          bind:tap="onToolTap"
        >
          <van-icon name="edit" size="14px" color="{{answerMode === 'handwrite' ? '#007AFF' : '#636366'}}" />
          <text>手写</text>
        </view>
        <view
          class="tool {{answerMode === 'keyboard' ? 'tool-prime' : ''}}"
          data-mode="keyboard"
          data-test-id="p08-tool-keyboard"
          bind:tap="onToolTap"
        >
          <van-icon name="comment-o" size="14px" color="{{answerMode === 'keyboard' ? '#007AFF' : '#636366'}}" />
          <text>键盘</text>
        </view>
        <view
          class="tool {{answerMode === 'formula' ? 'tool-prime' : ''}}"
          data-mode="formula"
          data-test-id="p08-tool-formula"
          bind:tap="onToolTap"
        >
          <van-icon name="star" size="14px" color="{{answerMode === 'formula' ? '#007AFF' : '#636366'}}" />
          <text>公式面板</text>
        </view>
      </view>
    </view>

    <!-- ── Reveal button (visible in ANSWERING state) ── -->
    <view wx:if="{{!isRevealed}}" class="reveal-btn-wrap">
      <van-button
        type="primary"
        size="large"
        round
        loading="{{isRevealing}}"
        disabled="{{execState !== 'ANSWERING' || isRevealing}}"
        data-test-id="p08-reveal-btn"
        bind:click="onRevealTap"
      >
        {{isRevealing ? '加载中…' : '👁 揭示答案'}}
      </van-button>
    </view>

    <!-- ── Reveal content ─────────────────────────────── -->
    <block wx:if="{{isRevealed}}">
      <view class="block-title block-title-green">
        <view class="block-title-dot block-title-dot-green"></view>
        <text>参考答案 · 已揭示</text>
      </view>
    </block>
    <view class="reveal {{isRevealed ? 'reveal-visible' : 'reveal-hidden'}}" data-test-id="p08-reveal-content">
      <view class="reveal-head">
        <view class="reveal-head-l">
          <view class="reveal-ico" data-test-id="p08-reveal-checkmark">
            <van-icon name="success" color="#fff" size="12px" />
          </view>
          <text class="reveal-ttl">标准解答</text>
        </view>
        <text class="reveal-sub">AI · GPT-4o mini</text>
      </view>
      <view class="ans">
        <text class="ans-k">顶点式</text>
        <text class="ans-v">{{question.answer}}</text>
      </view>
      <view class="steps">
        <view wx:for="{{steps}}" wx:key="num" class="stp" data-test-id="{{item.testId}}">
          <view class="stp-n">{{item.num}}</view>
          <text class="stp-t">{{item.text}}</text>
        </view>
      </view>
    </view>

    <!-- ── Node timeline ──────────────────────────────── -->
    <view class="nodes" data-test-id="memory-curve">
      <block wx:for="{{nodeDots}}" wx:key="idx">
        <view class="{{item.cls}}" data-test-id="memory-curve-node-{{item.tLevel}}"></view>
        <view wx:if="{{item.hasLine}}" class="node-line {{item.lineGreen ? 'node-line-green' : ''}}"></view>
      </block>
      <text class="node-label">{{nodeLabel}}</text>
    </view>

  </scroll-view>

  <!-- ── Rating bar (fixed bottom) ────────────────────── -->
  <view class="rating" data-test-id="p08-grade-buttons">
    <view class="rtitle">
      <text class="rtitle-l">本次复习你的自评？</text>
      <text class="rtitle-r">将用于更新记忆曲线</text>
    </view>
    <view class="ractions">
      <view
        class="rbtn rbtn-forgot {{!isRevealed || isGrading ? 'rbtn-disabled' : ''}}"
        data-grade="FORGOT"
        data-test-id="p08-grade-buttons-forgot"
        bind:tap="onGradeTap"
      >
        <view class="ri ri-red">✗</view>
        <text class="rl">未掌握</text>
        <text class="rs">回到 T0</text>
      </view>
      <view
        class="rbtn rbtn-partial {{!isRevealed || isGrading ? 'rbtn-disabled' : ''}}"
        data-grade="PARTIAL"
        data-test-id="p08-grade-buttons-partial"
        bind:tap="onGradeTap"
      >
        <view class="ri ri-orange">◐</view>
        <text class="rl">部分</text>
        <text class="rs">原计划不变</text>
      </view>
      <view
        class="rbtn rbtn-master {{!isRevealed || isGrading ? 'rbtn-disabled' : ''}}"
        data-grade="MASTERED"
        data-test-id="p08-grade-buttons-mastered"
        bind:tap="onGradeTap"
      >
        <view class="ri ri-green">✓</view>
        <text class="rl">已掌握</text>
        <text class="rs">推进到 T3</text>
      </view>
    </view>
  </view>

  <!-- ── Exit confirm sheet ───────────────────────────── -->
  <van-overlay show="{{showExitSheet}}" bind:click="onExitCancel" />
  <view wx:if="{{showExitSheet}}" class="sheet-overlay" data-test-id="p08-exit-confirm-sheet">
    <view class="sheet">
      <text class="sheet-title">退出本次复习？</text>
      <text class="sheet-body">本次复习尚未自评，退出将保留在原计划</text>
      <view class="sheet-actions">
        <van-button plain size="normal" bind:click="onExitCancel">取消</van-button>
        <van-button type="danger" size="normal" bind:click="onExitConfirm">退出</van-button>
      </view>
    </view>
  </view>

</view>
