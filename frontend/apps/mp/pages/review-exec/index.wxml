<!-- P08 复习执行 · 1:1 mirror of design/mockups/wrongbook/08_review_exec.html -->
<!-- trace: design/mockups/wrongbook/08_review_exec.html · @longfeng/testids p08 -->

<view class="review-exec-page" data-test-id="p08-root">

  <!-- ── Nav (mockup .nav) ──────────────────────────────── -->
  <view class="nav" data-test-id="p08-topbar">
    <view class="back" bind:tap="onBackTap">
      <van-icon name="arrow-left" color="#007AFF" size="22px" />
      <text>复习</text>
    </view>
    <view class="center">
      <text class="title" data-test-id="p08-topbar-cursor">复习执行 · 第 {{cursor}} 题</text>
      <text class="sub">{{cursor}} / {{total}} · 剩余 {{total - cursor}} 题</text>
      <!-- SC20-T05 AC2: <AiFlag> · nav center 紫色 "AI 已判" chip ·
           仅 aiJudgeStatus === 'DONE' 时显示 (helper: shouldShowAiFlag) -->
      <view wx:if="{{aiFlagVisible}}" class="ai-flag" data-test-id="{{aiJudgeIds.flag}}">
        <text>★ AI 已判</text>
      </view>
    </view>
    <view class="close" bind:tap="onCloseTap" data-test-id="p08-close-btn">
      <van-icon name="cross" color="#636366" size="14px" />
    </view>
    <view class="ptrack" data-test-id="p08-progress-bar">
      <text class="plbl">{{progressPct}}% · 预计 6 分钟</text>
      <view class="pbar" style="width: {{progressPct}}%;"></view>
    </view>
  </view>

  <!-- ── Scroll area ──────────────────────────────────── -->
  <scroll-view class="scroll" scroll-y="true">

    <!-- ── Meta chips ─────────────────────────────────── -->
    <view class="metarow" data-test-id="p08-meta-chips">
      <view class="chip chip-red">
        <view class="dot"></view>
        <text>{{node.tLevel}} · 第 {{node.nodeIndex + 1}} 次复习</text>
      </view>
      <view class="chip chip-indigo">
        <!-- kpName 空时不带 "· " 尾巴 · 之前 "数学 · " 难看 -->
        <text>{{question.subject}}{{question.kpName ? ' · ' + question.kpName : ''}}</text>
      </view>
      <view class="chip chip-orange">
        <text>{{difficultyLabel}} {{starsLabel}}</text>
      </view>
      <!-- SC20-T05 AC2: <AiMetaChip> · metarow 第 4 紫色 chip "AI 已判 {pct}%" ·
           仅 aiJudgeStatus === 'DONE' 时显示 (helper: deriveAiMetaChip) -->
      <view wx:if="{{metaChipVm.visible}}" class="chip chip-purple" data-test-id="{{aiJudgeIds.metaChip}}">
        <text>AI 已判 {{metaChipVm.pct}}%</text>
      </view>
    </view>

    <!-- ── Question card ──────────────────────────────── -->
    <view class="qcard" data-test-id="p08-question-hero">
      <text class="qkicker">错题回顾 · 原题</text>
      <view class="qstem">
        <text>{{question.stem}}</text>
      </view>
      <view class="qmeta">
        <!-- kpName 来自 BE knowledge_points join · 没 KP 时整行 hide · 之前死写 "顶点式·配方法" -->
        <text wx:if="{{question.kpName}}">知识点 · {{question.kpName}}</text>
        <text wx:else>—</text>
        <text class="stars">{{starsLabel}}</text>
      </view>
    </view>

    <!-- ── Work area ──────────────────────────────────── -->
    <!-- SC20-T04: photo mode 切到时 block-title 跟随 answerMode 切文案 (testid namespace 仅 4 必加 · 不在此挂) -->
    <view class="block-title">
      <view class="block-title-dot"></view>
      <text wx:if="{{answerMode === 'photo'}}">你的作答 · 拍照</text>
      <text wx:elif="{{answerMode === 'keyboard'}}">你的解答 · 键盘</text>
      <text wx:elif="{{answerMode === 'formula'}}">你的解答 · 公式</text>
      <text wx:else>你的解答 · 手写</text>
    </view>
    <view class="work" data-test-id="p08-answer-area" bind:touchstart="onCanvasTouch">
      <!-- ── Mode: handwrite ──
           原 mockup 在这里写死 "f(x)=x²−4x+3 = (x−2)²−1 顶点(2,−1)" 假装是学生笔迹 ·
           跟当前真题完全无关 · 是 mockup 透传 bug. spec §3 这是 AnswerArea ·
           学生先输出再揭示, 初始必须空 (canvas/paper 空白). 真 canvas 后续接入,
           暂用空 paper + 提示文案. -->
      <view wx:if="{{answerMode === 'handwrite'}}" class="paper">
        <view class="handwritten">
          <text wx:if="{{userAnswer}}">{{userAnswer}}</text>
          <text wx:else class="fm-placeholder">在此手写你的解答…（轻触开始）</text>
          <view class="cursor-blink"></view>
        </view>
      </view>

      <!-- ── Mode: keyboard (textarea 输入) ── -->
      <view wx:elif="{{answerMode === 'keyboard'}}" class="paper paper-input" catch:touchstart="onCanvasTouch">
        <textarea
          class="kb-input"
          placeholder="在此输入你的解答…"
          value="{{userAnswer}}"
          bindinput="onKeyboardInput"
          maxlength="-1"
          auto-height
          adjust-position="{{false}}"
          data-test-id="p08-answer-keyboard"
        />
      </view>

      <!-- ── Mode: formula (符号面板) ── -->
      <view wx:elif="{{answerMode === 'formula'}}" class="paper paper-input">
        <view class="fm-display" data-test-id="p08-answer-formula-display">
          <text wx:if="{{userAnswer}}">{{userAnswer}}</text>
          <text wx:else class="fm-placeholder">点下方符号拼接你的解答…</text>
        </view>
        <view class="fm-keypad" data-test-id="p08-answer-formula-keypad">
          <view
            wx:for="{{formulaSymbols}}"
            wx:key="*this"
            class="fm-key"
            data-sym="{{item}}"
            bind:tap="onFormulaInsert"
          >{{item}}</view>
          <view class="fm-key fm-key-util" bind:tap="onFormulaBackspace">⌫</view>
          <view class="fm-key fm-key-util" bind:tap="onFormulaClear">清空</view>
        </view>
      </view>

      <!-- ── Mode: photo (SC20-T04 · 第 4 input tab) ── -->
      <!-- 已上传: UploadedAnswerThumb (mockup L243-L271 视觉 · 120px 高 + 绿 badge + 元数据)
           上传中: progress placeholder (TI4 uploading 50% 态)
           IDLE / FAILED: 占位 + 提示文案 -->
      <view wx:elif="{{answerMode === 'photo'}}" class="paper paper-photo" data-test-id="{{aiJudgeIds.photoThumb}}">
        <block wx:if="{{photoState === 'UPLOADED' && userAnswerImageKey}}">
          <view class="photo-thumb">
            <view class="photo-thumb-placeholder">
              <text class="photo-thumb-glyph">📷</text>
              <text class="photo-thumb-key">{{userAnswerImageKey}}</text>
            </view>
            <view class="photo-badge-uploaded" data-test-id="{{aiJudgeIds.uploadBadge}}">
              <text>✓ 上传成功</text>
            </view>
            <view class="photo-meta" data-test-id="{{aiJudgeIds.photoMeta}}">
              <text>{{photoSizeLabel}} · {{photoCapturedAt}}</text>
            </view>
          </view>
        </block>
        <block wx:elif="{{photoState === 'UPLOADING'}}">
          <view class="photo-uploading">
            <text class="photo-uploading-text">上传中... {{photoUploadPct}}%</text>
            <view class="photo-progress-track">
              <view class="photo-progress-bar" style="width: {{photoUploadPct}}%;"></view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="photo-placeholder">
            <text class="photo-placeholder-glyph">📷</text>
            <text class="photo-placeholder-text">点击下方「拍照」拍下你的草稿纸作答</text>
          </view>
        </block>
      </view>

      <view class="tools">
        <view
          class="tool {{answerMode === 'handwrite' ? 'tool-prime' : ''}}"
          data-mode="handwrite"
          data-test-id="p08-tool-handwrite"
          bind:tap="onToolTap"
        >
          <van-icon name="edit" size="14px" color="{{answerMode === 'handwrite' ? '#007AFF' : '#636366'}}" />
          <text>手写</text>
        </view>
        <view
          class="tool {{answerMode === 'keyboard' ? 'tool-prime' : ''}}"
          data-mode="keyboard"
          data-test-id="p08-tool-keyboard"
          bind:tap="onToolTap"
        >
          <van-icon name="comment-o" size="14px" color="{{answerMode === 'keyboard' ? '#007AFF' : '#636366'}}" />
          <text>键盘</text>
        </view>
        <view
          class="tool {{answerMode === 'formula' ? 'tool-prime' : ''}}"
          data-mode="formula"
          data-test-id="p08-tool-formula"
          bind:tap="onToolTap"
        >
          <van-icon name="star" size="14px" color="{{answerMode === 'formula' ? '#007AFF' : '#636366'}}" />
          <text>公式面板</text>
        </view>
        <!-- SC20-T04: 第 4 input tab · active 时蓝色 prime 高亮 (mockup L295) -->
        <view
          class="tool {{answerMode === 'photo' ? 'tool-prime' : ''}}"
          data-mode="photo"
          data-test-id="{{aiJudgeIds.inputTabPhoto}}"
          bind:tap="onToolTap"
        >
          <van-icon name="photograph" size="14px" color="{{answerMode === 'photo' ? '#007AFF' : '#636366'}}" />
          <text>{{photoTabLabel}}</text>
        </view>
      </view>
    </view>

    <!-- ── Reveal button (visible in ANSWERING state) ── -->
    <view wx:if="{{!isRevealed}}" class="reveal-btn-wrap">
      <van-button
        type="primary"
        size="large"
        round
        loading="{{isRevealing}}"
        disabled="{{execState !== 'ANSWERING' || isRevealing}}"
        data-test-id="p08-reveal-btn"
        bind:click="onRevealTap"
      >
        {{isRevealing ? '加载中…' : '👁 揭示答案'}}
      </van-button>
    </view>

    <!-- ── Reveal content ─────────────────────────────── -->
    <block wx:if="{{isRevealed}}">
      <view class="block-title block-title-green">
        <view class="block-title-dot block-title-dot-green"></view>
        <text>参考答案 · 已揭示</text>
      </view>
    </block>
    <view class="reveal {{isRevealed ? 'reveal-visible' : 'reveal-hidden'}}" data-test-id="p08-reveal-content">
      <view class="reveal-head">
        <view class="reveal-head-l">
          <view class="reveal-ico" data-test-id="p08-reveal-checkmark">
            <van-icon name="success" color="#fff" size="12px" />
          </view>
          <text class="reveal-ttl">标准解答</text>
        </view>
        <text class="reveal-sub">AI · GPT-4o mini</text>
      </view>
      <view class="ans">
        <!-- 揭示答案区的 KP 标签: 用 question.kpName · 没 KP 不渲染 ·
             之前死写 "顶点式" 跟当前题无关 -->
        <text wx:if="{{question.kpName}}" class="ans-k">{{question.kpName}}</text>
        <text class="ans-v">{{question.answer}}</text>
      </view>
      <view class="steps">
        <view wx:for="{{steps}}" wx:key="num" class="stp" data-test-id="{{item.testId}}">
          <view class="stp-n">{{item.num}}</view>
          <text class="stp-t">{{item.text}}</text>
        </view>
      </view>
    </view>

<!-- ── SC20-T05 AC1: <AiJudgeBanner> ⭐ 核心新组件 ────
         5 子区 (head / verdict / reason / steps / actions) · 紫色 linear-gradient
         视觉 1:1 mockup design/mockups/wrongbook/20_review_exec_ai_judge.html L322-L385
         showMain · status === 'DONE' & verdict 非 null
         showFallback · status ∈ {TIMEOUT, LOW_CONFIDENCE, SERVICE_UNAVAILABLE} -->
    <view wx:if="{{aiJudgeStatus === 'PENDING'}}" class="aijb aijb-skeleton" data-test-id="{{aiJudgeIds.banner}}">
      <text class="aijb-thinking">{{thinkingText}}</text>
    </view>
    <view wx:if="{{bannerVm.showMain}}" class="aijb" data-test-id="{{aiJudgeIds.banner}}">
      <!-- Sub-zone 1 · head (avatar + title + sub + conf-pill) -->
      <view class="aijb-head" data-test-id="{{aiJudgeIds.bannerHead}}">
        <view class="aijb-avatar">
          <text>★</text>
        </view>
        <view class="aijb-head-col">
          <text class="aijb-ttl">AI 判定: {{bannerVm.verdictText}}</text>
          <text class="aijb-sub">{{bannerVm.modelSubtitle}}</text>
        </view>
        <view class="aijb-conf-pill" data-test-id="{{aiJudgeIds.confidence}}">
          <text>{{bannerVm.confidencePct}}% 把握</text>
        </view>
      </view>
      <!-- Sub-zone 2 · verdict 主区 (橙色 badge + label + hint) -->
      <view class="aijb-verdict" data-test-id="{{aiJudgeIds.verdictChip}}">
        <view class="aijb-verdict-badge">
          <text>◐</text>
        </view>
        <view class="aijb-verdict-col">
          <text class="aijb-verdict-label">{{aiJudgeVerdict}} · {{bannerVm.verdictText}}</text>
          <text class="aijb-verdict-hint">答案分析 · 步骤完成度 {{aiJudgeMatchedSteps.length}}/{{aiJudgeMatchedSteps.length + aiJudgeMissedSteps.length}}</text>
        </view>
      </view>
      <!-- Sub-zone 3 · reason 文本 -->
      <view class="aijb-reason" data-test-id="{{aiJudgeIds.reason}}">
        <text class="aijb-reason-label">诊断: </text>
        <text>{{aiJudgeReason}}</text>
      </view>
      <!-- Sub-zone 4 · step chips (ok + miss) -->
      <view class="aijb-steps">
        <view wx:for="{{aiJudgeMatchedSteps}}" wx:key="*this" class="aijb-step aijb-step-ok" data-test-id="{{aiJudgeIds.matchedStepsLi}}">
          <text>✓ {{item}}</text>
        </view>
        <view wx:for="{{aiJudgeMissedSteps}}" wx:key="*this" class="aijb-step aijb-step-miss" data-test-id="{{aiJudgeIds.missedStepsLi}}">
          <text>✗ {{item}}</text>
        </view>
      </view>
      <!-- Sub-zone 5 · actions (accept CTA + override CTA) -->
      <view class="aijb-actions">
        <view
          class="aijb-cta aijb-cta-accept {{!isRevealed ? 'aijb-cta-disabled' : ''}}"
          data-test-id="{{aiJudgeIds.ctaAccept}}"
          aria-label="采纳 AI 建议 · {{bannerVm.verdictText}}"
          bind:tap="onAcceptCtaTap"
        >
          <text>✓ {{acceptCtaText}}</text>
        </view>
        <view
          class="aijb-cta aijb-cta-override"
          data-test-id="{{aiJudgeIds.ctaOverride}}"
          aria-label="不采纳 · 我有不同看法"
          bind:tap="onOverrideCtaTap"
        >
          <text>{{overrideCtaText}}</text>
        </view>
      </view>
      <!-- SC21-T02 AC2 · override ack CTA · 学生 tap 非 AI 建议按钮后渲染 (biz §2B.21 步 2 字面) -->
      <view
        wx:if="{{overrideAckVm.visible}}"
        class="aijb-override-ack"
        data-test-id="{{aiJudgeIds.overrideAckCta}}"
        aria-label="{{overrideAckVm.text}}"
      >
        <text>{{overrideAckVm.text}}</text>
      </view>
    </view>
    <!-- SC20-T05 AC1 退化态 · fallback (banner 主区不渲染时显示) ·
         SC22-T01 视觉 polish: fallbackKind 决定 class (lowConfidence 灰 · timeout 红 + ⏱ · unavailable 灰 + ⚠) -->
    <view wx:if="{{bannerVm.showFallback}}" class="aijb aijb-fallback aijb-fallback-{{bannerVm.fallbackKind}}" data-test-id="{{aiJudgeIds.fallback}}">
      <text wx:if="{{bannerVm.fallbackKind === 'timeout'}}" class="aijb-fallback-icon aijb-fallback-icon-timeout">⏱</text>
      <text wx:elif="{{bannerVm.fallbackKind === 'unavailable'}}" class="aijb-fallback-icon aijb-fallback-icon-unavailable">⚠</text>
      <text wx:else class="aijb-fallback-icon aijb-fallback-icon-lowConfidence">🤔</text>
      <text class="aijb-fallback-text">{{bannerVm.fallbackText}}</text>
    </view>

    <!-- ── Node timeline ──────────────────────────────── -->
    <view class="nodes" data-test-id="memory-curve">
      <block wx:for="{{nodeDots}}" wx:key="idx">
        <view class="{{item.cls}}" data-test-id="memory-curve-node-{{item.tLevel}}"></view>
        <view wx:if="{{item.hasLine}}" class="node-line {{item.lineGreen ? 'node-line-green' : ''}}"></view>
      </block>
      <text class="node-label">{{nodeLabel}}</text>
    </view>

  </scroll-view>

  <!-- ── Rating bar (fixed bottom) ────────────────────── -->
  <view class="rating" data-test-id="p08-grade-buttons">
    <!-- SC20-T05 AC2: <AiHintRibbon> · rating 上方紫色 hint banner ·
         仅 aiJudgeStatus === 'DONE' 时显示 (helper: deriveAiHintRibbon) -->
    <view wx:if="{{hintRibbonVm.visible}}" class="ai-hint" data-test-id="{{aiJudgeIds.hintRibbon}}">
      <text class="ai-hint-mark">★</text>
      <text class="ai-hint-text">AI 建议: <text class="ai-hint-emp">{{hintRibbonVm.verdictText}}</text> · 1 tap 即采纳 · 或选其他 override</text>
    </view>
    <view class="rtitle">
      <text class="rtitle-l">本次复习你的自评？</text>
      <text class="rtitle-r">将用于更新记忆曲线</text>
    </view>
    <!-- SC20-T05 AC3: GradeButtons preselected ring + AiMark · 用 gradeBtnsVm 渲染
         - preselected 对应按钮: cls 含 rbtn-preselected (双 border + box-shadow)
         - 角标: showMark=true 时渲染 .ai-mark (AI★)
         - 色盲友好: aria-label 含 "· AI 建议" 后缀 (不仅靠颜色 · 满足 TI2 + A.1)
         注: wx:for 必须保持 mockup 顺序 (FORGOT → PARTIAL → MASTERED) -->
    <view class="ractions">
      <block wx:for="{{gradeBtnsVm}}" wx:key="grade">
        <view
          class="{{item.cls}}"
          data-grade="{{item.grade}}"
          data-test-id="p08-grade-buttons-{{item.grade === 'FORGOT' ? 'forgot' : item.grade === 'PARTIAL' ? 'partial' : 'mastered'}}"
          aria-label="{{item.ariaLabel}}"
          bind:tap="onGradeTap"
        >
          <!-- AiMark · preselected 才显示 · 视觉角标 (mockup L353 + L417) -->
          <view wx:if="{{item.showMark}}" class="ai-mark" data-test-id="{{aiJudgeIds.aiMark}}">
            <text>AI★</text>
          </view>
          <view class="ri ri-{{item.grade === 'FORGOT' ? 'red' : item.grade === 'PARTIAL' ? 'orange' : 'green'}}">{{item.grade === 'FORGOT' ? '✗' : item.grade === 'PARTIAL' ? '◐' : '✓'}}</view>
          <text class="rl">{{item.grade === 'FORGOT' ? '未掌握' : item.grade === 'PARTIAL' ? '部分' : '已掌握'}}</text>
          <text class="rs">{{item.grade === 'FORGOT' ? '回到 T0' : item.grade === 'PARTIAL' ? '原计划不变' : '推进到 T3'}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- ── Exit confirm sheet ───────────────────────────── -->
  <van-overlay show="{{showExitSheet}}" bind:click="onExitCancel" />
  <view wx:if="{{showExitSheet}}" class="sheet-overlay" data-test-id="p08-exit-confirm-sheet">
    <view class="sheet">
      <text class="sheet-title">退出本次复习？</text>
      <text class="sheet-body">本次复习尚未自评，退出将保留在原计划</text>
      <view class="sheet-actions">
        <van-button plain size="normal" bind:click="onExitCancel">取消</van-button>
        <van-button type="danger" size="normal" bind:click="onExitConfirm">退出</van-button>
      </view>
    </view>
  </view>

</view>
