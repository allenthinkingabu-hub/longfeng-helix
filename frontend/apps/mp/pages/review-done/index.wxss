/* P09 复习完成页样式 · 1:1 mirror design/mockups/wrongbook/09_review_done.html */

/* ── CSS Variables (matching mockup :root) ───────────────── */
page {
  --bg: #F2F2F7;
  --card: #FFFFFF;
  --sep: rgba(60,60,67,0.14);
  --text: #1C1C1E;
  --sec: #636366;
  --ter: #8E8E93;
  --blue: #007AFF;
  --red: #FF3B30;
  --orange: #FF9500;
  --green: #34C759;
  --indigo: #5856D6;
  background: var(--bg);
}

/* ── Hero celebration ────────────────────────────────────── */
.hero {
  position: relative;
  width: 100%;
  height: 660rpx;
  background: linear-gradient(175deg, #0F7F3E 0%, #1FAE5C 40%, #34C759 100%);
  overflow: hidden;
}

.hero::before,
.hero::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  opacity: 0.6;
}

.hero::before {
  width: 440rpx;
  height: 440rpx;
  background: #6DFFA1;
  top: -120rpx;
  left: -120rpx;
  filter: blur(72rpx);
}

.hero::after {
  width: 520rpx;
  height: 520rpx;
  background: #0B6B30;
  bottom: -200rpx;
  right: -160rpx;
  filter: blur(72rpx);
}

.hero--forgot {
  background: linear-gradient(175deg, #CC6600 0%, #FF9500 100%);
}

.confetti {
  position: absolute;
  left: 0; top: 0; right: 0; bottom: 0;
  pointer-events: none;
  opacity: 0.9;
}

.confetti-particle {
  position: absolute;
  width: 12rpx;
  height: 20rpx;
  border-radius: 4rpx;
  opacity: 0.85;
}

/* Hero icon */
.hero-icon {
  position: absolute;
  top: 196rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 208rpx;
  height: 208rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  border: 4rpx solid rgba(255,255,255,0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.22), inset 0 4rpx 0 rgba(255,255,255,0.35);
}

.hero-icon-core {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #FFFFFF, #E4FFEC);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-icon-svg {
  width: 88rpx;
  height: 88rpx;
}

.hero-kicker {
  position: absolute;
  top: 420rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: rgba(255,255,255,0.85);
  text-transform: uppercase;
}

.hero-title {
  position: absolute;
  top: 460rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 0.6rpx;
}

.hero-sub {
  position: absolute;
  top: 544rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.86);
  letter-spacing: 0.6rpx;
}

.hero-chips {
  position: absolute;
  top: 596rpx;
  left: 0; right: 0;
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.hero-chip {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
  border: 2rpx solid rgba(255,255,255,0.28);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.6rpx;
}

/* ── Skeleton ────────────────────────────────────────────── */
.skeleton {
  padding: 32rpx;
}

.skeleton-card {
  height: 200rpx;
  background: rgba(120,120,128,0.12);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-bar {
  height: 32rpx;
  background: rgba(120,120,128,0.12);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

/* ── Scroll content ──────────────────────────────────────── */
.scroll {
  position: absolute;
  top: 620rpx;
  left: 0; right: 0;
  bottom: 168rpx;
  padding: 64rpx 32rpx 48rpx;
  background: var(--bg);
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
  box-shadow: 0 -36rpx 48rpx rgba(0,0,0,0.04);
}

/* ── Block title ─────────────────────────────────────────── */
.block-title {
  margin: 0 4rpx 20rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ter);
  letter-spacing: 2.4rpx;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.block-title-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--green);
}

.block-title-right {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--sec);
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

/* ── Card ────────────────────────────────────────────────── */
.card {
  background: var(--card);
  border-radius: 32rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

/* ── Memory curve head ───────────────────────────────────── */
.mc-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 4rpx 4rpx 16rpx;
}

.mc-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.mc-sub {
  font-size: 22rpx;
  color: var(--ter);
  font-weight: 600;
  margin-top: 4rpx;
}

.mc-right {
  text-align: right;
}

.mc-mastery {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--green);
  letter-spacing: 0.6rpx;
  line-height: 1;
}

.mc-mastery-label {
  font-size: 20rpx;
  color: var(--ter);
  font-weight: 600;
  letter-spacing: 1.2rpx;
  text-transform: uppercase;
}

/* ── 6-node timeline ─────────────────────────────────────── */
.nodes-container {
  margin-top: 24rpx;
  position: relative;
  padding: 28rpx 4rpx 44rpx;
}

.nodes-row {
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.node {
  width: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.node-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(120,120,128,0.22);
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx rgba(120,120,128,0.18);
}

.node-dot--done {
  background: var(--green);
  box-shadow: 0 0 0 4rpx rgba(52,199,89,0.22);
}

.node-dot--now {
  background: linear-gradient(135deg, #5AA3FF, #0062E1);
  box-shadow: 0 0 0 8rpx rgba(0,122,255,0.18);
}

.node-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--sec);
  letter-spacing: 0.8rpx;
}

.node-label--done {
  color: var(--green);
}

.node-label--now {
  color: var(--blue);
}

.node-date {
  font-size: 18rpx;
  color: var(--ter);
  font-weight: 600;
}

/* ── Advance banner ──────────────────────────────────────── */
.advance {
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, rgba(52,199,89,0.10), rgba(0,122,255,0.08));
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.advance-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #34C759, #007AFF);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
}

.advance-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text);
  font-weight: 600;
  line-height: 1.4;
}

.advance-text-em {
  color: var(--blue);
  font-weight: 800;
}

/* ── Next due card ───────────────────────────────────────── */
.next-card {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  background: var(--card);
  border-radius: 32rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

.next-left {
  display: flex;
  gap: 24rpx;
  align-items: center;
}

.next-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #E9FAF0, #C7F0D6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.next-kicker {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ter);
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

.next-date {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  margin-top: 4rpx;
}

.next-memo {
  font-size: 22rpx;
  color: var(--sec);
  font-weight: 500;
  margin-top: 4rpx;
}

.add-calendar-btn {
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: rgba(0,122,255,0.12);
  color: var(--blue);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.add-calendar-btn--done {
  opacity: 0.5;
}

/* ── Stats grid ──────────────────────────────────────────── */
.stats {
  display: flex;
  gap: 16rpx;
}

.stat {
  flex: 1;
  background: var(--card);
  border-radius: 28rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

.stat-big {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -0.6rpx;
}

.stat-green { color: var(--green); }
.stat-blue { color: var(--blue); }
.stat-orange { color: var(--orange); }

.stat-label {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--ter);
  letter-spacing: 0.8rpx;
  text-transform: uppercase;
}

/* ── KP list ─────────────────────────────────────────────── */
.kp-list {
  background: var(--card);
  border-radius: 32rpx;
  padding: 12rpx 28rpx;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.04);
}

.kp-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--sep);
}

.kp-row:last-child {
  border-bottom: none;
}

.kp-square {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
}

.kp-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text);
  font-weight: 600;
}

.kp-bar {
  width: 160rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: rgba(120,120,128,0.14);
  overflow: hidden;
  position: relative;
}

.kp-bar-fill {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  border-radius: 6rpx;
}

.kp-pct {
  width: 68rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--sec);
}

/* ── CTA dock ────────────────────────────────────────────── */
.cta {
  position: fixed;
  left: 0; right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(env(safe-area-inset-bottom) + 28rpx);
  background: rgba(242,242,247,0.88);
  backdrop-filter: blur(22px) saturate(180%);
  border-top: 1rpx solid var(--sep);
  display: flex;
  gap: 20rpx;
  z-index: 35;
}

.btn-sec {
  flex: 1;
  border-radius: 32rpx !important;
}

.btn-pri {
  flex: 1;
  border-radius: 32rpx !important;
}
