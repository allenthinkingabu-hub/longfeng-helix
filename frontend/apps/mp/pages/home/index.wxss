/* P-HOME 首页 · 1:1 mirror of design/mockups/wrongbook/01_home.html */
/* trace: design/mockups/wrongbook/01_home.html */

page {
  background: #F2F2F7;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "PingFang SC", sans-serif;
  color: #1C1C1E;
}

.home-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── Hero aurora gradient (B8 · 240px → 480rpx 紧凑) ─────── */
.hero {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(180deg, #1E3A8A 0%, #3B5BDB 45%, #5B8DEF 100%);
  z-index: 1;
}

/* ── Greeting (B8 · 紧贴顶部 · 减少 hero 上方空白) ────────── */
.greeting {
  position: fixed;
  top: 80rpx;
  left: 40rpx;
  right: 40rpx;
  z-index: 10;
  color: #fff;
}

.hello-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.hello {
  font-size: 26rpx;
  font-weight: 400;
  letter-spacing: 0.4rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 8rpx;
}

.name-text {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: -1.6rpx;
  line-height: 1.14;
}

.name-em {
  color: #FFD166;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD166, #FF9500, #FF2D55, #5856D6);
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: #fff;
  font-size: 30rpx;
}

.streak-bar {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.88);
}

.flame {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
}

.flame-icon {
  font-size: 24rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.45);
}

.mastered-num {
  color: #6DE895;
  font-weight: 800;
}

/* ── Scroll area (B7 · view + page 整页滚动 · B8 · 上沿与 hero 紧贴) ─ */
/* 原 scroll-view flex:1 无 height MP 不滚 KP 卡 / Quick entries 看不到 */
/* 改为 普通 view + 由 page (body) 整页 vertical scroll · margin-top 让出 hero+greeting 高度 */
.scroll {
  position: relative;
  margin-top: 360rpx;
  padding: 28rpx 28rpx 120rpx;
  z-index: 5;
  background: #F2F2F7;
  border-top-left-radius: 48rpx;
  border-top-right-radius: 48rpx;
}

/* ── Skeleton ────────────────────────────────────────── */
.skeleton {
  padding: 28rpx 0;
}

.skeleton-card {
  height: 320rpx;
  border-radius: 36rpx;
  background: rgba(120, 120, 128, 0.12);
  margin-bottom: 24rpx;
}

.skeleton-card-sm {
  height: 200rpx;
}

.skeleton-bar {
  height: 28rpx;
  border-radius: 14rpx;
  background: rgba(120, 120, 128, 0.12);
  margin-bottom: 16rpx;
}

/* ── Error banner ────────────────────────────────────── */
.error-banner {
  padding: 16rpx 24rpx;
  background: rgba(255, 149, 0, 0.15);
  border-radius: 16rpx;
  color: #FF9500;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}

/* ── Empty hero ──────────────────────────────────────── */
.empty-hero {
  text-align: center;
  padding: 60rpx 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
}

.empty-hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

/* ── Review hero card ────────────────────────────────── */
.review-card {
  position: relative;
  background: linear-gradient(135deg, #0d1b45 0%, #1a3a8a 60%, #4055cc 100%);
  border-radius: 44rpx;
  padding: 36rpx 36rpx 32rpx;
  color: #fff;
  overflow: hidden;
  box-shadow: 0 16rpx 56rpx rgba(26, 58, 138, 0.30);
}

.rh-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.rh-kicker {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2.4rpx;
  color: rgba(255, 255, 255, 0.60);
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.rh-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1.13;
}

.rh-title-em {
  color: #FFD166;
}

.rh-sub {
  font-size: 24rpx;
  font-weight: 400;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.62);
  letter-spacing: 0.4rpx;
}

/* ── Progress ring (CSS-only circle approximation) ──── */
.rh-circle {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  flex: none;
}

.rh-circle-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 12rpx solid rgba(255, 255, 255, 0.15);
}

.rh-circle-track {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 12rpx solid transparent;
  border-top-color: #FFD166;
  border-right-color: #FF9500;
  transform: rotate(-90deg);
}

.rh-pct {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.rh-pct-n {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: -0.6rpx;
  line-height: 1;
}

.rh-pct-l {
  font-size: 18rpx;
  font-weight: 600;
  letter-spacing: 1.6rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 4rpx;
}

/* ── Subject chips ───────────────────────────────────── */
.rh-split {
  margin-top: 28rpx;
  display: flex;
  gap: 16rpx;
}

.rh-sub-chip {
  flex: 1;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.rh-sq {
  width: 16rpx;
  height: 16rpx;
  border-radius: 6rpx;
}

.rh-ct {
  color: rgba(255, 255, 255, 0.82);
}

.rh-ct-em {
  color: #fff;
  font-weight: 800;
  margin-right: 4rpx;
}

/* ── CTA ─────────────────────────────────────────────── */
.rh-cta {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.rh-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  background: #fff;
  color: #0d1b45;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: -0.2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(255, 255, 255, 0.18);
}

.rh-btn-play {
  font-size: 24rpx;
}

.rh-btn2 {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
}

/* ── Section title ───────────────────────────────────── */
.sec {
  margin: 36rpx 8rpx 20rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.sec-t {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: -0.2rpx;
  color: #1C1C1E;
}

.sec-m {
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 600;
  letter-spacing: 0.4rpx;
}

.sec-m-orange {
  color: #FF9500;
}

/* ── Weekly summary ──────────────────────────────────── */
.weekly {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.weekly-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.stat {
  flex: 1;
  text-align: center;
}

.stat-n {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -0.4rpx;
  line-height: 1;
}

.stat-l {
  font-size: 20rpx;
  font-weight: 700;
  color: #8E8E93;
  letter-spacing: 1.2rpx;
  margin-top: 8rpx;
  text-transform: uppercase;
}

.stat-green { color: #34C759; }
.stat-blue { color: #007AFF; }
.stat-orange { color: #FF9500; }
.stat-indigo { color: #5856D6; }

.stat-sep {
  flex: none;
  width: 2rpx;
  height: 64rpx;
  background: rgba(60, 60, 67, 0.14);
}

/* ── (B3) Sparkline 折线 + 7 日 days bar ────────────────────── */
.spark {
  margin-top: 24rpx;
  position: relative;
  height: 88rpx;
  padding-top: 8rpx;
}

.spark-svg {
  width: 100%;
  height: 100%;
  display: block;
}

.days {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  font-size: 18rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.8rpx;
}

.day {
  flex: 1;
  text-align: center;
}

.day-today {
  color: #007AFF;
  font-weight: 800;
}

/* ── Week schedule card ──────────────────────────────── */
.weekcard {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.wc-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.wc-head-l {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #1C1C1E;
}

.wc-expand {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #007AFF;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(0, 122, 255, 0.08);
}

.wc-row {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.wd {
  padding: 16rpx 0 12rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(120, 120, 128, 0.06);
  position: relative;
  min-height: 144rpx;
}

.wd-today {
  background: linear-gradient(180deg, #007AFF, #0062E1);
}

.wd-w {
  font-size: 18rpx;
  font-weight: 700;
  color: #8E8E93;
  letter-spacing: 1.2rpx;
}

.wd-today .wd-w,
.wd-today .wd-d {
  color: #fff;
}

.wd-d {
  font-size: 30rpx;
  font-weight: 800;
  color: #1C1C1E;
  line-height: 1;
}

.wd-dots {
  margin-top: 4rpx;
  display: flex;
  gap: 4rpx;
  align-items: center;
  flex-wrap: wrap;
  justify-content: center;
  max-width: 64rpx;
}

.wd-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.wd-today .wd-dot {
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.5);
}

.wd-num {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  background: #FF3B30;
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  border: 3rpx solid #fff;
}

.wc-foot {
  margin-top: 20rpx;
  padding: 16rpx 4rpx 0;
  border-top: 1rpx solid rgba(60, 60, 67, 0.14);
  font-size: 22rpx;
  color: #636366;
  font-weight: 600;
}

.wc-legend {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.wc-lg-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.wc-lg-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* ── Messages ────────────────────────────────────────── */
.msgs {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 8rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.msg {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(60, 60, 67, 0.14);
}

.msg:last-child {
  border-bottom: none;
}

.msg-ic {
  flex: none;
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.msg-ic-ind { background: rgba(88, 86, 214, 0.12); }
.msg-ic-pnk { background: rgba(255, 45, 85, 0.12); }
.msg-ic-tea { background: rgba(48, 176, 199, 0.12); }

.msg-tx {
  flex: 1;
  min-width: 0;
}

.msg-t {
  font-size: 26rpx;
  font-weight: 700;
  color: #1C1C1E;
  line-height: 1.3;
}

.msg-s {
  font-size: 22rpx;
  color: #636366;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-tm {
  flex: none;
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.6rpx;
}

/* ── KP card (orange warm) ───────────────────────────── */
.kpcard {
  background: linear-gradient(135deg, #FFF4E6 0%, #FFE5C4 100%);
  border: 1rpx solid rgba(255, 149, 0, 0.22);
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  position: relative;
  overflow: hidden;
}

.kp-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.kp-head-ic {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FF9500, #FF6B00);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.kp-head-ttl {
  font-size: 26rpx;
  font-weight: 800;
  color: #7A3800;
  letter-spacing: -0.2rpx;
}

.kp-head-em {
  color: #C84B00;
}

.kp-body {
  font-size: 24rpx;
  color: #8B4A1A;
  line-height: 1.55;
  margin-bottom: 20rpx;
}

.kp-strong {
  font-weight: 800;
  color: #5C2800;
}

.kp-actions {
  display: flex;
  gap: 16rpx;
}

.kpbtn {
  flex: 1;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.kpbtn-pr {
  background: linear-gradient(180deg, #FF9500, #E07800);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 149, 0, 0.25);
}

.kpbtn-sc {
  background: rgba(255, 255, 255, 0.65);
  color: #7A3800;
  border: 1rpx solid rgba(139, 74, 26, 0.18);
}

/* ── Quick entries ───────────────────────────────────── */
.quick {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.qcard {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.qcard-ic {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  flex: none;
}

.qcard-ic-red { background: linear-gradient(135deg, #FF6B6B, #FF3B30); }
.qcard-ic-grn { background: linear-gradient(135deg, #5DD87A, #34C759); }
.qcard-ic-blu { background: linear-gradient(135deg, #5BA8FF, #007AFF); }
.qcard-ic-pur { background: linear-gradient(135deg, #C581F7, #8B87F6); }

.qcard-tx {
  flex: 1;
  min-width: 0;
}

.qcard-t {
  font-size: 26rpx;
  font-weight: 700;
  color: #1C1C1E;
  line-height: 1.2;
}

.qcard-s {
  font-size: 20rpx;
  color: #8E8E93;
  font-weight: 600;
  letter-spacing: 0.4rpx;
  margin-top: 4rpx;
}
