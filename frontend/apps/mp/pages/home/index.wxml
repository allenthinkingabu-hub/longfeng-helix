<!-- P-HOME 首页 · 1:1 mirror of design/mockups/wrongbook/01_home.html -->
<!-- trace: design/mockups/wrongbook/01_home.html · @longfeng/testids pHome -->
<!-- 状态机: LOADING → READY | EMPTY | ERROR -->

<view class="home-page" data-test-id="p-home-root">

  <!-- ── Hero aurora gradient ──────────────────────────── -->
  <view class="hero"></view>

  <!-- ── Greeting ──────────────────────────────────────── -->
  <view class="greeting" data-test-id="greeting-hero">
    <view class="hello-row">
      <view>
        <view class="hello">{{greeting}}</view>
        <view class="name-text">{{studentName}}，<text class="name-em">今天继续</text></view>
      </view>
      <view class="avatar">A</view>
    </view>
    <!-- spec §3 <StreakBar> + mastered chip (2026-05-18 用户决策 · 接 wrongbook 真值)
         streak 真值: backend WeeklyAggregateService · GET /api/home/today.weekSummary.streak
         mastered 真值: backend HomeAggregatorController 跨服务调 wrongbook-service ·
                       GET /api/home/today.today.masteredTotal (mastery=2 OR status=ARCHIVED)
         spec §5 L166: streak=0 时 chip 隐藏 · mastered=0 同样隐藏 (无累计掌握不展示假数据) -->
    <view class="streak-bar" wx:if="{{streak > 0 || mastered > 0}}">
      <view class="flame" data-test-id="streak-bar-fire-icon" wx:if="{{streak > 0}}">
        <text class="flame-icon">🔥</text>
        <text data-test-id="streak-bar-days-number">连续 {{streak}} 天</text>
      </view>
      <view class="dot" wx:if="{{streak > 0 && mastered > 0}}"></view>
      <text wx:if="{{mastered > 0}}">掌握 <text class="mastered-num">{{mastered}}</text> 题</text>
    </view>
  </view>

  <!-- ── Scroll area (B7 · view + page 整页滚动 · 原 scroll-view 无 height MP 不滚) ─ -->
  <view class="scroll">

    <!-- ── LOADING skeleton ──────────────────────────── -->
    <view wx:if="{{pageState === 'LOADING'}}" class="skeleton">
      <view class="skeleton-card"></view>
      <view class="skeleton-bar" style="width: 60%;"></view>
      <view class="skeleton-bar" style="width: 85%;"></view>
      <view class="skeleton-card skeleton-card-sm"></view>
    </view>

    <!-- ── ERROR banner ──────────────────────────────── -->
    <view wx:if="{{pageState === 'ERROR'}}" class="error-banner">
      <text>部分数据正在同步</text>
    </view>

    <!-- ── EMPTY hero ────────────────────────────────── -->
    <view wx:if="{{pageState === 'EMPTY'}}" class="review-card empty-hero">
      <view class="empty-hero-title">今天没有复习安排</view>
      <text>拍一道新题试试？</text>
    </view>

    <!-- ── READY: Review hero card ───────────────────── -->
    <block wx:if="{{pageState === 'READY'}}">

      <view class="review-card" data-test-id="today-review-card">
        <view class="rh-top">
          <view>
            <view class="rh-kicker">TODAY'S REVIEW</view>
            <!-- allDone 态切庆祝文案 · 与 P07 hero ALL_DONE 同模型 · 撤掉"100% DONE+N 题待复习"内部打架 -->
            <view class="rh-title">
              <block wx:if="{{allDone}}">
                <text class="rh-title-em" data-test-id="today-review-card-total">今日复习已完成 🎉</text>
              </block>
              <block wx:else>
                <text class="rh-title-em" data-test-id="today-review-card-total">{{todayTotal}} 题</text>
                <text> 待复习</text>
              </block>
            </view>
            <view class="rh-sub">
              <block wx:if="{{allDone}}">共 {{todayTotal}} 题 · 已全部完成</block>
              <block wx:else>预计 {{estMin}} 分钟</block>
            </view>
          </view>
          <view class="rh-circle" data-test-id="today-review-card-circle-progress">
            <view class="rh-circle-bg"></view>
            <view class="rh-circle-track" style="--progress: {{circleProgress}};"></view>
            <view class="rh-pct">
              <text class="rh-pct-n">{{circlePctText}}</text>
              <text class="rh-pct-l">DONE</text>
            </view>
          </view>
        </view>

        <!-- Subject chips -->
        <view class="rh-split">
          <view wx:for="{{subjects}}" wx:key="name" class="rh-sub-chip">
            <view class="rh-sq" style="background: {{item.color}};"></view>
            <text class="rh-ct"><text class="rh-ct-em">{{item.count}}</text>{{item.name}}</text>
          </view>
        </view>

        <!-- CTA -->
        <view class="rh-cta">
          <view class="rh-btn" bind:tap="onStartAll" data-test-id="today-review-card-start-all-btn">
            <text class="rh-btn-play">▶</text>
            <text>全部开始</text>
          </view>
          <view class="rh-btn2">
            <van-icon name="plus" color="#fff" size="16px" />
          </view>
        </view>
      </view>
    </block>

    <!-- ── 始终渲染 sections (LOADING/READY/EMPTY/ERROR 共用 home framework) ─── -->
    <block>

      <!-- ── Weekly summary (SC-16-T02 · weekSummary 4 数字 wire to today.weekSummary · INV-6) -->
      <view class="sec">
        <text class="sec-t">本周回顾</text>
        <text
          class="sec-m"
          data-test-id="{{testIds.weeklyHomeLink}}"
          bind:tap="onWeeklyHomeTap"
        >查看全部 ›</text>
      </view>
      <view class="weekly" data-test-id="p-home-weekly-sparkline">
        <!-- 4 维度 stat (mastered/newItems/forgotten/masteryRate) · 真值走
             /api/home/weekly-stats (不再 hardcode 23/8/2/68%) ·
             用户 2026-05-18 决策: 恢复 4 维度但喂真值 + 保 sparkline 曲线 -->
        <view class="weekly-row">
          <view class="stat">
            <text class="stat-n stat-green">{{weekStats.mastered}}</text>
            <text class="stat-l">掌握</text>
          </view>
          <view class="stat-sep"></view>
          <view class="stat">
            <!-- 复用 SC-16-T02 testid p-home-week-new-count: newItems 语义同
                 "本周新增" · TC-6 E2E + unit 仍命中 -->
            <text
              class="stat-n stat-blue"
              data-test-id="{{testIds.weekSummary.newCountNum}}"
            >{{weekStats.newItems}}</text>
            <text class="stat-l">新增</text>
          </view>
          <view class="stat-sep"></view>
          <view class="stat">
            <text class="stat-n stat-orange">{{weekStats.forgotten}}</text>
            <text class="stat-l">遗忘</text>
          </view>
          <view class="stat-sep"></view>
          <view class="stat">
            <!-- 复用 SC-16-T02 testid p-home-week-mastery-num: masteryRate 语义同
                 "掌握率" · TC-6 E2E + unit 仍命中 -->
            <text
              class="stat-n stat-indigo"
              data-test-id="{{testIds.weekSummary.masteryRateNum}}"
            >{{weekStats.masteryRate}}%</text>
            <text class="stat-l">掌握率</text>
          </view>
        </view>
        <!-- Sparkline 曲线: 严格真值 (B 方案 2026-05-18 用户决策) ·
             仅 BE /today.weekSummary.sparkline 有真值时渲染 · 空周不画
             (防 mockup 假曲线穿透 · 与 P03/P04 治理同根) ·
             日期 bar 仍渲染让"周一→今天"标尺继续可视 -->
        <view class="spark" data-test-id="{{testIds.weekSummary.sparklineSvg}}">
          <image
            wx:if="{{weekSummarySparklineUri}}"
            class="spark-svg"
            src="{{weekSummarySparklineUri}}"
            mode="scaleToFill"
          />
        </view>
        <!-- 2026-05-18 用户决策修: day bar 标签动态化 ·
             "今天"贴在 ISO 周对应位置 (周一=index 0 ... 周日=index 6) ·
             之前写死 [周一,周二,...,周六,今天] 假设今天=周日 → 错位 bug -->
        <view class="days" data-test-id="p-home-weekly-days">
          <text
            wx:for="{{weekDayLabels}}"
            wx:key="*this"
            class="day {{index === todayIdx ? 'day-today' : ''}}"
          >{{item}}</text>
        </view>
      </view>

      <!-- ── Week schedule ───────────────────────────── -->
      <view class="sec">
        <text class="sec-t">本周日程</text>
        <text class="sec-m" bind:tap="onMonthViewTap">月视图 ›</text>
      </view>
      <view class="weekcard" data-test-id="week-strip">
        <view class="wc-head">
          <view class="wc-head-l">
            <van-icon name="calendar-o" size="14px" color="#1C1C1E" />
            <text>{{weekLabel}}</text>
          </view>
          <view class="wc-expand">
            <text>展开</text>
            <van-icon name="arrow" size="10px" color="#007AFF" />
          </view>
        </view>
        <view class="wc-row">
          <view wx:for="{{weekDays}}" wx:key="w" class="wd {{item.today ? 'wd-today' : ''}}">
            <text class="wd-w">{{item.w}}</text>
            <text class="wd-d">{{item.d}}</text>
            <view class="wd-dots">
              <view wx:for="{{item.dots}}" wx:for-item="dot" wx:key="*this" class="wd-dot" style="background: {{dot}};"></view>
            </view>
            <text wx:if="{{item.num}}" class="wd-num">{{item.num}}</text>
          </view>
        </view>
        <view class="wc-foot">
          <view class="wc-legend">
            <view class="wc-lg-item"><view class="wc-lg-dot" style="background: #FF3B30;"></view><text>复习 T1</text></view>
            <view class="wc-lg-item"><view class="wc-lg-dot" style="background: #FF9500;"></view><text>T3</text></view>
            <view class="wc-lg-item"><view class="wc-lg-dot" style="background: #34C759;"></view><text>T6</text></view>
            <view class="wc-lg-item"><view class="wc-lg-dot" style="background: #FF2D55;"></view><text>考试</text></view>
            <view class="wc-lg-item"><view class="wc-lg-dot" style="background: #5856D6;"></view><text>家庭</text></view>
          </view>
        </view>
      </view>

      <!-- ── Messages · BE 派生 ≤3 条 (替代 MVP_MESSAGES 写死) ── -->
      <view class="sec">
        <text class="sec-t">最近消息</text>
        <text wx:if="{{messages.length > 0}}" class="sec-m" data-test-id="p-home-messages-more-link">全部 {{messages.length}} ›</text>
      </view>
      <view wx:if="{{messages.length > 0}}" class="msgs" data-test-id="p-home-messages">
        <view wx:for="{{messages}}" wx:key="title" class="msg">
          <view class="msg-ic msg-ic-{{item.theme}}">
            <van-icon name="{{item.icon}}" color="{{item.iconColor}}" size="16px" />
          </view>
          <view class="msg-tx">
            <text class="msg-t">{{item.title}}</text>
            <text class="msg-s">{{item.subtitle}}</text>
          </view>
          <text class="msg-tm">{{item.time}}</text>
        </view>
      </view>
      <!-- 空态 · 不假装有 3 条 "妈妈分享 / 免打扰" mock -->
      <view wx:else class="msgs msgs-empty" data-test-id="p-home-messages-empty">
        <text class="msgs-empty-tx">本周暂无消息</text>
      </view>

      <!-- ── AI Weak KP ──────────────────────────────── -->
      <view class="sec">
        <text class="sec-t">AI 发现的薄弱点</text>
        <text class="sec-m sec-m-orange">1 条待练</text>
      </view>
      <view class="kpcard" data-test-id="p-home-weak-kp">
        <view class="kp-head">
          <view class="kp-head-ic">
            <van-icon name="warning-o" color="#fff" size="14px" />
          </view>
          <text class="kp-head-ttl">「<text class="kp-head-em">韦达定理</text>」最近 4 次都错了</text>
        </view>
        <view class="kp-body">
          <text>AI 检测到你在同一知识点上的错误在<text class="kp-strong">加速积累</text>。建议开启一次针对性专练（约 5 分钟），系统会同步写入你的记忆曲线。</text>
        </view>
        <view class="kp-actions">
          <view class="kpbtn kpbtn-pr">
            <text>▶ 立即专练</text>
          </view>
          <view class="kpbtn kpbtn-sc">
            <text>稍后再说</text>
          </view>
        </view>
      </view>

      <!-- ── Quick entries ───────────────────────────── -->
      <view class="quick" data-test-id="p-home-quick-entries">
        <view wx:for="{{quickEntries}}" wx:key="title" class="qcard" bind:tap="onQuickTap" data-url="{{item.url}}">
          <view class="qcard-ic qcard-ic-{{item.theme}}">
            <van-icon name="{{item.icon}}" color="#fff" size="18px" />
          </view>
          <view class="qcard-tx">
            <text class="qcard-t">{{item.title}}</text>
            <text class="qcard-s">{{item.subtitle}}</text>
          </view>
          <van-icon name="arrow" color="#8E8E93" size="10px" />
        </view>
      </view>

    </block>

  </view>

</view>
