{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2017"],
    "types": ["miniprogram-api-typings"],
    "paths": {
      "@longfeng/testids": ["../../packages/testids/src/index.ts"],
      "@longfeng/api-contracts": ["../../packages/api-contracts/src/index.ts"],
      "@longfeng/telemetry": ["../../packages/telemetry/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": [
    "**/*.ts",
    "typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "test"
  ]
}
